<UserControl x:Class="e_learning_app.ExamManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F8FAFC"
             Loaded="UserControl_Loaded">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- ==================== HEADER ==================== -->
		<Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,20">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<!-- Title & Subtitle -->
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="📋 Quản Lý Bài Kiểm Tra"
                             FontSize="28" FontWeight="Bold"
                             Foreground="#1E293B"
                             Margin="0,0,0,4"/>
					<TextBlock Text="Tạo, chỉnh sửa và quản lý các bài thi cho lớp học của bạn"
                             FontSize="13" Foreground="#64748B"/>
				</StackPanel>

				<!-- Create Button -->
				<Button x:Name="BtnCreateExam"
                       Grid.Column="1"
                       Content="➕ Tạo Bài Thi Mới"
                       Background="#3B82F6"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Padding="18,12,18,12"
                       BorderThickness="0"
                       Cursor="Hand"
                       Click="BtnCreateExam_Click">
					<Button.Resources>
						<Style TargetType="Button">
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Button">
										<Border Background="{TemplateBinding Background}"
                                               CornerRadius="8"
                                               Padding="{TemplateBinding Padding}">
											<ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
										</Border>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</Button.Resources>
				</Button>
			</Grid>
		</Border>

		<!-- ==================== MAIN CONTENT ==================== -->
		<Grid Grid.Row="1" Margin="24">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="260"/>
				<ColumnDefinition Width="20"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- ==================== SIDEBAR - FILTERS ==================== -->
			<Border Grid.Column="0"
                   Background="White"
                   CornerRadius="12"
                   Padding="20">

				<ScrollViewer VerticalScrollBarVisibility="Auto">
										<StackPanel>
						<!-- Filter Title -->
						<TextBlock Text="🔍 BỘ LỌC TÌM KIẾM"
                                 FontSize="13"
                                 FontWeight="Bold"
                                 Foreground="#1E293B"
                                 Margin="0,0,0,16"/>

						<!-- Search -->
						<TextBlock Text="TÌM KIẾM"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="#475569"
                                 Margin="0,0,0,8"/>
						<Border Background="#F1F5F9" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,16">
							<TextBox x:Name="TxtSearch"
                                    Height="36"
                                    Padding="10,0"
                                    FontSize="13"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    VerticalContentAlignment="Center"
                                    TextChanged="TxtSearch_TextChanged"/>
						</Border>

						<!-- Divider -->
						<Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,16"/>

						<!-- Subject Filter -->
						<TextBlock Text="MÔN HỌC"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="#475569"
                                 Margin="0,0,0,8"/>
						<Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,16">
							<ComboBox x:Name="CboSubject"
                                     Height="36"
                                     Padding="10,0"
                                     FontSize="13"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     SelectionChanged="Filter_Changed">
								<ComboBoxItem Content="Tất cả môn học" IsSelected="True"/>
								<ComboBoxItem Content="SE104.O21 - Công nghệ phần mềm"/>
								<ComboBoxItem Content="CS101 - Nhập môn lập trình"/>
							</ComboBox>
						</Border>

						<!-- Divider -->
						<Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,16"/>

						<!-- Status Filter -->
						<TextBlock Text="TRẠNG THÁI"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="#475569"
                                 Margin="0,0,0,10"/>
						<CheckBox x:Name="ChkActive"
                                 Content="✅ Đang Mở"
                                 Margin="0,0,0,10"
                                 FontSize="13"
                                 Foreground="#1E293B"
                                 Checked="Filter_Changed"
                                 Unchecked="Filter_Changed"
                                 Tag="active"/>
						<CheckBox x:Name="ChkClosed"
                                 Content="🔒 Đã Khóa"
                                 Margin="0,0,0,10"
                                 FontSize="13"
                                 Foreground="#1E293B"
                                 Checked="Filter_Changed"
                                 Unchecked="Filter_Changed"
                                 Tag="closed"/>
						<CheckBox x:Name="ChkDraft"
                                 Content="📝 Nháp"
                                 Margin="0,0,0,16"
                                 FontSize="13"
                                 Foreground="#1E293B"
                                 Checked="Filter_Changed"
                                 Unchecked="Filter_Changed"
                                 Tag="draft"/>

						<!-- Divider -->
						<Rectangle Height="1" Fill="#E2E8F0" Margin="0,0,0,16"/>

						<!-- Exam Type Filter -->
						<TextBlock Text="LOẠI BÀI THI"
                                 FontSize="11"
                                 FontWeight="SemiBold"
                                 Foreground="#475569"
                                 Margin="0,0,0,10"/>
						<CheckBox x:Name="ChkQuiz"
                                 Content="🎯 Quiz"
                                 Margin="0,0,0,10"
                                 FontSize="13"
                                 Foreground="#1E293B"
                                 Checked="Filter_Changed"
                                 Unchecked="Filter_Changed"
                                 Tag="Quiz"/>
						<CheckBox x:Name="ChkMidterm"
                                 Content="📚 Giữa Kỳ"
                                 Margin="0,0,0,10"
                                 FontSize="13"
                                 Foreground="#1E293B"
                                 Checked="Filter_Changed"
                                 Unchecked="Filter_Changed"
                                 Tag="Midterm"/>
						<CheckBox x:Name="ChkFinal"
                                 Content="🏆 Cuối Kỳ"
                                 Margin="0,0,0,10"
                                 FontSize="13"
                                 Foreground="#1E293B"
                                 Checked="Filter_Changed"
                                 Unchecked="Filter_Changed"
                                 Tag="Final"/>
						<CheckBox x:Name="ChkPractice"
                                 Content="💪 Luyện Tập"
                                 Margin="0,0,0,10"
                                 FontSize="13"
                                 Foreground="#1E293B"
                                 Checked="Filter_Changed"
                                 Unchecked="Filter_Changed"
                                 Tag="Practice"/>
					</StackPanel>
				</ScrollViewer>
			</Border>

			<!-- ==================== MAIN CONTENT AREA ==================== -->
			<StackPanel Grid.Column="2">
				<!-- Stats Cards -->
				<Grid Height="100" Margin="0,0,0,20">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="16"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="16"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<!-- Total Exams Card -->
					<Border Grid.Column="0"
                           Background="White"
                           CornerRadius="12"
                           Padding="20">
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="📊 Tổng Bài Thi"
                                     FontSize="12"
                                     Foreground="#64748B"
                                     Margin="0,0,0,8"/>
							<TextBlock x:Name="TxtTotalExams"
                                     Text="0"
                                     FontSize="32"
                                     FontWeight="Bold"
                                     Foreground="#1E293B"/>
						</StackPanel>
					</Border>

					<!-- Active Exams Card -->
					<Border Grid.Column="2"
                           Background="White"
                           CornerRadius="12"
                           Padding="20">
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="✅ Đang Mở"
                                     FontSize="12"
                                     Foreground="#64748B"
                                     Margin="0,0,0,8"/>
							<TextBlock x:Name="TxtActiveExams"
                                     Text="0"
                                     FontSize="32"
                                     FontWeight="Bold"
                                     Foreground="#3B82F6"/>
						</StackPanel>
					</Border>

					<!-- Pending Exams Card -->
					<Border Grid.Column="4"
                           Background="White"
                           CornerRadius="12"
                           Padding="20">
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="⏳ Chờ Phê Duyệt"
                                     FontSize="12"
                                     Foreground="#64748B"
                                     Margin="0,0,0,8"/>
							<TextBlock x:Name="TxtPendingExams"
                                     Text="0"
                                     FontSize="32"
                                     FontWeight="Bold"
                                     Foreground="#F59E0B"/>
						</StackPanel>
					</Border>
				</Grid>

				<!-- Exams List Title -->
				<TextBlock Text="📝 DANH SÁCH BÀI THI"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="#1E293B"
                         Margin="0,0,0,16"/>

				<!-- Exams Scrollable List -->
				<ScrollViewer VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            Height="500">
					<StackPanel x:Name="ExamsPanel"/>
				</ScrollViewer>

				<!-- Empty State -->
				<Border x:Name="EmptyState"
                       Background="White"
                       CornerRadius="12"
                       Padding="40"
                       Visibility="Collapsed">
					<StackPanel VerticalAlignment="Center"
                              HorizontalAlignment="Center">
						<TextBlock Text="📭"
                                 FontSize="64"
                                 Foreground="#CBD5E1"
                                 TextAlignment="Center"
                                 Margin="0,0,0,16"/>
						<TextBlock Text="Chưa có bài thi nào"
                                 FontSize="16"
                                 FontWeight="SemiBold"
                                 Foreground="#64748B"
                                 TextAlignment="Center"
                                 Margin="0,0,0,8"/>
						<TextBlock Text="Hãy tạo bài thi đầu tiên của bạn"
                                 FontSize="12"
                                 Foreground="#94A3B8"
                                 TextAlignment="Center"/>
					</StackPanel>
				</Border>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>