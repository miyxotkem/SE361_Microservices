<UserControl x:Class="e_learning_app.Views.TeacherDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding"      Value="22,18"/>
            <Setter Property="Background"   Value="White"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.07" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin"     Value="0,0,0,14"/>
        </Style>
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding"      Value="10,4"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScheduleCard" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin"          Value="0,0,0,10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="14" Padding="16,14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30,30,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TxtGreeting"
                               FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock x:Name="TxtTodayInfo"
                               FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnCreateClass"
                            Content="+ Tạo lớp học"
                            Style="{StaticResource ActionBtn}"
                            Background="#3B82F6" Foreground="White"
                            Margin="0,0,10,0"
                            Click="BtnCreateClass_Click"/>
                    <Button x:Name="BtnCreateExam"
                            Content="📋  Tạo bài kiểm tra"
                            Style="{StaticResource ActionBtn}"
                            Background="#EFF6FF" Foreground="#3B82F6"
                            Click="BtnCreateExam_Click"/>
                </StackPanel>
            </Grid>

            <!-- STAT CARDS -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="12" Background="#EFF6FF" HorizontalAlignment="Left">
                            <TextBlock Text="👨‍🎓" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtTotalStudents" FontSize="30" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Tổng học sinh" FontSize="12" Foreground="#64748B"/>
                            <Border Style="{StaticResource Pill}" Background="#DCFCE7" Margin="8,0,0,0">
                                <TextBlock x:Name="TxtStudentTrend" FontSize="10" Foreground="#16A34A" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="12" Background="#FFF7ED" HorizontalAlignment="Left">
                            <TextBlock Text="🎓" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtTotalClasses" FontSize="30" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Lớp đang dạy" FontSize="12" Foreground="#64748B"/>
                            <Border Style="{StaticResource Pill}" Background="#FEF9C3" Margin="8,0,0,0">
                                <TextBlock x:Name="TxtSemesterBadge" FontSize="10" Foreground="#CA8A04" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="12" Background="#FFF1F2" HorizontalAlignment="Left">
                            <TextBlock Text="📝" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtPendingGrading" FontSize="30" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Chờ chấm điểm" FontSize="12" Foreground="#64748B"/>
                            <Border Style="{StaticResource Pill}" Background="#FEE2E2" Margin="8,0,0,0">
                                <TextBlock Text="Cần xử lý" FontSize="10" Foreground="#DC2626" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="12" Background="#F0FDF4" HorizontalAlignment="Left">
                            <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtAvgScore" FontSize="30" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Điểm trung bình" FontSize="12" Foreground="#64748B"/>
                            <Border Style="{StaticResource Pill}" Background="#DCFCE7" Margin="8,0,0,0">
                                <TextBlock x:Name="TxtScoreTrend" FontSize="10" Foreground="#16A34A" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="310"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Schedule -->
                <StackPanel Grid.Column="0">
                    <Grid Margin="0,0,0,14">
                        <TextBlock Text="📅  Lịch dạy hôm nay" Style="{StaticResource SectionHeader}" Margin="0"/>
                        <TextBlock x:Name="TxtTodayDate" FontSize="12" Foreground="#64748B"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Schedule cards - clickable Buttons -->
                    <Button x:Name="BtnClass1" Style="{StaticResource ScheduleCard}"
                            Tag="12A1" Click="BtnScheduleClass_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" x:Name="BarClass1" CornerRadius="3"/>
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="TxtClass1Name" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock x:Name="TxtClass1Time" FontSize="12" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " Foreground="#CBD5E1"/>
                                    <TextBlock x:Name="TxtClass1Room" FontSize="12" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " Foreground="#CBD5E1"/>
                                    <TextBlock x:Name="TxtClass1Students" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="3" x:Name="PillClass1" Style="{StaticResource Pill}" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtClass1Status" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button x:Name="BtnClass2" Style="{StaticResource ScheduleCard}"
                            Tag="11B3" Click="BtnScheduleClass_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" x:Name="BarClass2" CornerRadius="3"/>
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="TxtClass2Name" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock x:Name="TxtClass2Time" FontSize="12" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " Foreground="#CBD5E1"/>
                                    <TextBlock x:Name="TxtClass2Room" FontSize="12" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " Foreground="#CBD5E1"/>
                                    <TextBlock x:Name="TxtClass2Students" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="3" x:Name="PillClass2" Style="{StaticResource Pill}" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtClass2Status" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button x:Name="BtnClass3" Style="{StaticResource ScheduleCard}"
                            Tag="12C2" Click="BtnScheduleClass_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" x:Name="BarClass3" CornerRadius="3"/>
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="TxtClass3Name" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock x:Name="TxtClass3Time" FontSize="12" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " Foreground="#CBD5E1"/>
                                    <TextBlock x:Name="TxtClass3Room" FontSize="12" Foreground="#64748B"/>
                                    <TextBlock Text="  ·  " Foreground="#CBD5E1"/>
                                    <TextBlock x:Name="TxtClass3Students" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Grid.Column="3" x:Name="PillClass3" Style="{StaticResource Pill}" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtClass3Status" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- RIGHT: Todo + Notifications -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="✅  Việc cần làm" Style="{StaticResource SectionHeader}"/>
                    <Border Background="White" CornerRadius="18" Padding="18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <StackPanel x:Name="TodoPanel">
                            <!-- Populated by code-behind -->
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,20,0,14">
                        <TextBlock Text="🔔  Thông báo mới" Style="{StaticResource SectionHeader}" Margin="0"/>
                        <Button x:Name="BtnViewAllNotif" Content="Xem tất cả →"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#3B82F6" FontSize="12" FontWeight="SemiBold"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Cursor="Hand" Click="BtnViewAllNotif_Click"/>
                    </Grid>
                    <Border Background="White" CornerRadius="18" Padding="18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <StackPanel x:Name="NotifPanel">
                            <!-- Populated by code-behind -->
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
