<UserControl x:Class="e_learning_app.ForgotPasswordControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             d:DesignHeight="500" d:DesignWidth="400">

    <StackPanel VerticalAlignment="Center">
        <TextBlock Text="Khôi phục mật khẩu" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,10"/>
        <TextBlock Text="Nhập email của bạn để nhận link đặt lại mật khẩu nhé." 
                   FontSize="14" Foreground="{StaticResource TextMuted}" Margin="0,0,0,30" TextWrapping="Wrap" LineHeight="20"/>

        <TextBlock Text="Email dang ký" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource TextDark}"/>
        <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="15,10" Margin="0,0,0,20">
            <TextBox x:Name="txtResetEmail" Background="Transparent" BorderThickness="0" FontSize="14" VerticalAlignment="Center" />
        </Border>

        <TextBlock x:Name="txtStatus" FontSize="12" Margin="0,0,0,15" TextWrapping="Wrap"/>

        <Button x:Name="btnSendRequest" Content="Gửi yêu cầu khôi phục" 
                Style="{StaticResource PrimaryButtonStyle}" Click="btnSendRequest_Click">
            <Button.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.15" Color="#3B82F6"/>
            </Button.Effect>
        </Button>

        <TextBlock Text="Quay lại Đăng nhập" Foreground="{StaticResource PrimaryBlue}" 
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,25,0,0" 
                   Cursor="Hand" MouseDown="BackToLogin_Click"/>
    </StackPanel>
</UserControl>