<UserControl x:Class="e_learning_app.Views.NotificationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <!-- Filter / Tab Button -->
        <Style x:Key="FilterTabBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Margin"     Value="0,0,10,0"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="12" Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Unread Notification Item Style -->
        <Style x:Key="NotifUnread" TargetType="Border">
            <Setter Property="Background"   Value="#EFF6FF"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding"      Value="18"/>
            <Setter Property="Margin"       Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.04" Color="#3B82F6"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Read Notification Item Style -->
        <Style x:Key="NotifRead" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding"      Value="18"/>
            <Setter Property="Margin"       Value="0,0,0,12"/>
            <Setter Property="BorderBrush"  Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,30,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="🔔  Thông báo chung" Style="{StaticResource SectionHeader}" FontSize="24"/>
                <TextBlock Text="Thông báo hệ thống và tin nhắn từ giáo viên" FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnMarkAllRead" Content="✓ Đánh dấu tất cả"
                        Background="Transparent" BorderThickness="0" Foreground="#3B82F6"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,15,0"
                        Click="BtnMarkAllRead_Click"/>
            </StackPanel>
        </Grid>

        <!-- TABS FILTER -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <RadioButton x:Name="BtnFilterAll" Content="Tất cả" Style="{StaticResource FilterTabBtn}" IsChecked="True" Checked="FilterTab_Checked" Tag="all"/>
            <RadioButton x:Name="BtnFilterUnread" Content="Chua đọc" Style="{StaticResource FilterTabBtn}" Checked="FilterTab_Checked" Tag="unread"/>
            <RadioButton x:Name="BtnFilterRead" Content="Đã xem" Style="{StaticResource FilterTabBtn}" Checked="FilterTab_Checked" Tag="read"/>
        </StackPanel>

        <!-- LIST NOTIFICATIONS -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="NotifItemsControl" ItemsSource="{Binding Notifications}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="NotifBorder" Style="{StaticResource NotifRead}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon Area -->
                                <Border Grid.Column="0" Width="46" Height="46" CornerRadius="14" Background="#F1F5F9" Margin="0,0,16,0">
                                    <TextBlock Text="{Binding Icon}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Content -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock Text="{Binding Content}" FontSize="13" Foreground="#64748B" Margin="0,4,0,4" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding TimeAgo}" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>

                                <!-- Actions -->
                                <Button Grid.Column="2" Content="Xem chi tiết" 
                                        Click="BtnViewNotif_Click"
                                        Background="Transparent" BorderThickness="0" Foreground="#3B82F6"
                                        FontSize="12" Cursor="Hand" VerticalAlignment="Top"/>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsRead}" Value="False">
                                <Setter TargetName="NotifBorder" Property="Style" Value="{StaticResource NotifUnread}"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
