<UserControl x:Class="e_learning_app.RegisterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             d:DesignHeight="500" d:DesignWidth="400">

    <StackPanel VerticalAlignment="Center">
        <TextBlock Text="Tạo tài khoản" FontSize="32" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,10"/>
        <TextBlock Text="Bắt đầu hành trình học tập cùng EduFlow." FontSize="14" Foreground="{StaticResource TextMuted}" Margin="0,0,0,30"/>

        <TextBlock Text="Họ và tên" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource TextDark}"/>
        <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="15,10" Margin="0,0,0,15">
            <TextBox x:Name="txtFullName" Background="Transparent" BorderThickness="0" FontSize="14" VerticalAlignment="Center" />
        </Border>

        <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource TextDark}"/>
        <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="15,10" Margin="0,0,0,15">
            <TextBox x:Name="txtEmail" Background="Transparent" BorderThickness="0" FontSize="14" VerticalAlignment="Center" />
        </Border>

        <TextBlock Text="Mật khẩu" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource TextDark}"/>
        <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="15,10" Margin="0,0,0,15">
            <PasswordBox x:Name="txtPassword" Background="Transparent" BorderThickness="0" FontSize="14" VerticalAlignment="Center" />
        </Border>
        <Button Content="Đăng ký ngay" Style="{StaticResource PrimaryButtonStyle}" Margin="0,10,0,25" Click="Register_Click">
            <Button.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.15" Color="#3B82F6"/>
            </Button.Effect>
        </Button>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="Đã có tài khoản?" Foreground="{StaticResource TextMuted}"/>
            <TextBlock Text=" Đăng nhập" Foreground="{StaticResource PrimaryBlue}" FontWeight="Bold" Margin="5,0,0,0" Cursor="Hand" MouseDown="GoToLogin_Click"/>
        </StackPanel>
    </StackPanel>
</UserControl>