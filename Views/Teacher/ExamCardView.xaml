<UserControl x:Class="e_learning_app.ExamCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:e_learning_app"
             mc:Ignorable="d" 
             d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Style for action buttons -->
        <!-- Style for action buttons -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Delete Action Button Style -->
        <Style x:Key="DeleteActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#EF4444"/>
                    <Setter Property="Background" Value="#FEF2F2"/>
                    <Setter Property="BorderBrush" Value="#FEE2E2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style for Status Text -->
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D97706"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="NHÁP"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPublished}" Value="True">
                    <Setter Property="Text" Value="ĐÃ KHÓA"/>
                    <Setter Property="Foreground" Value="#DC2626"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsPublished}" Value="True"/>
                        <Condition Binding="{Binding IsActive}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Text" Value="ĐANG MỞ"/>
                    <Setter Property="Foreground" Value="#16A34A"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Style for Status Icon -->
        <Style x:Key="StatusIconStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D97706"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="📝"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPublished}" Value="True">
                    <Setter Property="Text" Value="🔒"/>
                    <Setter Property="Foreground" Value="#DC2626"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsPublished}" Value="True"/>
                        <Condition Binding="{Binding IsActive}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Text" Value="✅"/>
                    <Setter Property="Foreground" Value="#16A34A"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Style for Status Border Background -->
        <Style x:Key="StatusBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFBEB"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="BorderBrush" Value="#FEF3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPublished}" Value="True">
                    <Setter Property="Background" Value="#FEF2F2"/>
                    <Setter Property="BorderBrush" Value="#FEE2E2"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsPublished}" Value="True"/>
                        <Condition Binding="{Binding IsActive}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#F0FDF4"/>
                    <Setter Property="BorderBrush" Value="#DCFCE7"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="White" 
            BorderBrush="#E2E8F0" 
            BorderThickness="1" 
            CornerRadius="16" 
            Padding="24"
            Margin="0,0,0,16"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>
        <!-- Subtle shadow -->
        <Border.Effect>
            <DropShadowEffect x:Name="CardShadow" BlurRadius="15" ShadowDepth="2" Opacity="0.05" Color="#1E293B"/>
        </Border.Effect>
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.01" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.01" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0.1" Duration="0:0:0.2" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="25" Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0.05" Duration="0:0:0.2" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="15" Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        
        <StackPanel>
            <!-- ================= TOP BADGES ================= -->
            <WrapPanel Orientation="Horizontal" Margin="0,0,0,20">
                <!-- Quiz Badge -->
                <Border Background="#EFF6FF" CornerRadius="8" Padding="10,4" Margin="0,0,12,6" BorderBrush="#DBEAFE" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎯" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Type, FallbackValue=Quiz}" Foreground="#2563EB" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <!-- Status Badge -->
                <Border Style="{StaticResource StatusBorderStyle}" Margin="0,0,12,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource StatusIconStyle}"/>
                        <TextBlock Style="{StaticResource StatusTextStyle}"/>
                    </StackPanel>
                </Border>
                
                <!-- Duration Badge -->
                <Border Background="#F8FAFC" CornerRadius="8" Padding="10,4" Margin="0,0,12,6" BorderBrush="#F1F5F9" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏱" Foreground="#64748B" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TimeLimitMinutes, StringFormat='\{0\} phút', FallbackValue='30 phút'}" Foreground="#64748B" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Deadline Badge -->
                <Border Background="#FEF2F2" CornerRadius="8" Padding="10,4" Margin="0,0,12,6" BorderBrush="#FEE2E2" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Deadline}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏳" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Deadline, StringFormat='Hạn: \{0:dd/MM/yyyy HH:mm\}'}" Foreground="#DC2626" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
            
            <!-- ================= MIDDLE ROW (Title & Actions) ================= -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Title & ClassName -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title, FallbackValue='Quiz Chuong 1: Giới Thiệu Lập Trình'}" 
                                FontSize="20" 
                                FontWeight="Bold" 
                                Foreground="#1E293B" 
                                TextWrapping="Wrap"
                                Margin="0,0,0,6"/>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏫" Foreground="#94A3B8" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ClassName, FallbackValue='SE104.O21 - Công nghệ phần mềm'}" 
                                   FontSize="13" 
                                   Foreground="#64748B" 
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   FontWeight="Medium"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button x:Name="BtnView" Style="{StaticResource ActionButtonStyle}" Tag="{Binding Id}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👁" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Xem" FontSize="13" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnEdit" Style="{StaticResource ActionButtonStyle}" Tag="{Binding Id}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✎" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sửa" FontSize="13" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnDelete" Style="{StaticResource DeleteActionButtonStyle}" Tag="{Binding Id}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Xóa" FontSize="13" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
            
            <!-- ================= SUBTITLE ================= -->
            <TextBlock Text="{Binding Description, FallbackValue='Kiểm tra kiến thức co bản về C# và OOP'}" 
                       Foreground="#64748B" 
                       FontSize="14" 
                       Margin="0,0,0,20"
                       TextWrapping="Wrap"
                       LineHeight="20"/>
            
            <!-- ================= BOTTOM DETAILS ================= -->
            <Border BorderBrush="#F1F5F9" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                <StackPanel Orientation="Horizontal">
                    <!-- Question Count -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📊" Foreground="#94A3B8" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalQuestions, StringFormat='\{0\} câu hỏi', FallbackValue='10 câu hỏi'}" Foreground="#64748B" FontSize="13" VerticalAlignment="Center" FontWeight="Medium"/>
                    </StackPanel>
                    
                    <TextBlock Text="•" Foreground="#CBD5E1" FontSize="14" Margin="12,0" VerticalAlignment="Center"/>
                    
                    <!-- Pass Score -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🎯" Foreground="#94A3B8" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PassingScore, StringFormat='Đạt: \{0\}%', FallbackValue='Đạt: 50%'}" Foreground="#64748B" FontSize="13" VerticalAlignment="Center" FontWeight="Medium"/>
                    </StackPanel>
                    
                    <TextBlock Text="•" Foreground="#CBD5E1" FontSize="14" Margin="12,0" VerticalAlignment="Center"/>
                    
                    <!-- Date -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📅" Foreground="#94A3B8" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CreatedAt, StringFormat='Tạo: \{0:dd/MM/yyyy\}', FallbackValue='Tạo: 12/04/2026'}" Foreground="#64748B" FontSize="13" VerticalAlignment="Center" FontWeight="Medium"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
