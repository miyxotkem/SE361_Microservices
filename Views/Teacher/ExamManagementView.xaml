<UserControl x:Class="e_learning_app.ExamManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:e_learning_app"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F8FAFC"
             Loaded="UserControl_Loaded">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==================== HEADER ==================== -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title & Subtitle -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="📋 Quản Lý Bài Kiểm Tra"
                             FontSize="24" FontWeight="Bold"
                             Foreground="#1E293B"
                             Margin="0,0,0,2"/>
                    <TextBlock Text="Tạo và quản lý các bài thi, bài tập trắc nghiệm"
                             FontSize="12" Foreground="#64748B"/>
                </StackPanel>

                <!-- Compact Stats: Total -->
                <Border Grid.Column="2" CornerRadius="12" Padding="16,10" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#F1F5F9" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.04" Color="Black"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📊" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="Tổng" FontSize="10" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtTotalExams" Text="0" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Compact Stats: Active -->
                <Border Grid.Column="4" CornerRadius="12" Padding="16,10" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#EFF6FF" Offset="0"/>
                            <GradientStop Color="#DBEAFE" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.04" Color="Black"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="✅" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="Đang Mở" FontSize="10" Foreground="#2563EB" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtActiveExams" Text="0" FontSize="22" FontWeight="Bold" Foreground="#1E40AF"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Compact Stats: Pending -->
                <Border Grid.Column="6" CornerRadius="12" Padding="16,10" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFBEB" Offset="0"/>
                            <GradientStop Color="#FEF3C7" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.04" Color="Black"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⏳" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="Chờ Duyệt" FontSize="10" Foreground="#D97706" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtPendingExams" Text="0" FontSize="22" FontWeight="Bold" Foreground="#92400E"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Create Button -->
                <Button x:Name="BtnCreateExam"
                       Grid.Column="8"
                       Content="➕ Tạo Bài Thi Mới"
                       Background="#3B82F6"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       Padding="24,12"
                       BorderThickness="0"
                       Cursor="Hand"
                       Click="BtnCreateExam_Click">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="12"
                                                Padding="{TemplateBinding Padding}">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="#3B82F6"/>
                                            </Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- ==================== MAIN CONTENT ==================== -->
        <Grid Grid.Row="1" Margin="32,20,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ==================== FILTERS BAR ==================== -->
            <Border Grid.Row="0" Background="White" CornerRadius="14" Padding="20,14" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                        <TextBox x:Name="TxtSearch" Height="36" Padding="12,0" FontSize="13" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" TextChanged="TxtSearch_TextChanged"/>
                    </Border>

                    <TextBlock Grid.Column="3" Text="Môn:" FontSize="12" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Border Grid.Column="4" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                        <ComboBox x:Name="CboSubject" Height="36" Padding="12,0" FontSize="13" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" SelectionChanged="Filter_Changed"/>
                    </Border>

                    <TextBlock Grid.Column="6" Text="Lọc:" FontSize="12" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="ChkActive" Content="Đang Mở" Margin="0,0,14,0" FontSize="12" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="active"/>
                        <CheckBox x:Name="ChkClosed" Content="Đã Khóa" Margin="0,0,14,0" FontSize="12" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="closed"/>
                        <CheckBox x:Name="ChkDraft" Content="Nháp" FontSize="12" Checked="Filter_Changed" Unchecked="Filter_Changed" Tag="draft"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== EXAM LIST AREA ==================== -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📝 DANH SÁCH BÀI THI"
                         FontSize="14"
                         FontWeight="Bold"
                         Foreground="#1E293B"
                         Margin="0,0,0,20"/>

                <!-- Exams ListBox -->
                <ListBox x:Name="ExamsList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" IsItemsHost="True" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <local:ExamCardView Width="500"
                                ViewClicked="ExamCard_ViewClicked"
                                EditClicked="ExamCard_EditClicked"
                                DeleteClicked="ExamCard_DeleteClicked"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,24,24"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Empty State -->
                    <Border x:Name="EmptyState"
                           Grid.Row="1"
                           Background="White"
                           CornerRadius="20"
                           Padding="60"
                           Visibility="Collapsed"
                           VerticalAlignment="Top">
                        <StackPanel VerticalAlignment="Center"
                                  HorizontalAlignment="Center">
                            <TextBlock Text="📭"
                                     FontSize="72"
                                     Foreground="#CBD5E1"
                                     TextAlignment="Center"
                                     Margin="0,0,0,24"/>
                            <TextBlock Text="Chưa có bài thi nào"
                                     FontSize="20"
                                     FontWeight="Bold"
                                     Foreground="#64748B"
                                     TextAlignment="Center"
                                     Margin="0,0,0,8"/>
                            <TextBlock Text="Hãy tạo bài thi đầu tiên để bắt đầu đánh giá học sinh"
                                     FontSize="14"
                                     Foreground="#94A3B8"
                                     TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </Grid>
</UserControl>