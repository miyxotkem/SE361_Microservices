<UserControl x:Class="e_learning_app.CreateExamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:e_learning_app"
             Background="#F8FAFC">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="FieldLabelStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionHeaderStyle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,20,0,14"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10"/>
                            <ContentPresenter Margin="12,0,30,0" VerticalAlignment="Center" Content="{TemplateBinding SelectionBoxItem}" IsHitTestVisible="False"/>
                            <Path x:Name="Arrow" Data="M0,0 L4,4 L8,0 Z" Fill="#94A3B8" HorizontalAlignment="Right" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <ToggleButton Background="Transparent" BorderThickness="0" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="250" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.12" Color="Black"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter Margin="4"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="6" Margin="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#3B82F6"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox" x:Key="ModernCheckBoxStyle">
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="CheckBox" Width="20" Height="20" CornerRadius="6" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" VerticalAlignment="Center">
                                <TextBlock x:Name="CheckMark" Text="✓" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" FontWeight="Bold"/>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBox" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="CheckBox" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBox" Property="Background" Value="#3B82F6"/>
                                <Setter TargetName="CheckBox" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern DatePicker Style -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                <Grid Margin="12,0,8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <DatePickerTextBox x:Name="PART_TextBox"
                                        Grid.Column="0"
                                        Foreground="{TemplateBinding Foreground}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                                    <Button x:Name="PART_Button" Grid.Column="1"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Width="28" Height="28"
                                        VerticalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" Padding="2">
                                                    <TextBlock Text="📅" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Placement="Bottom"
                                IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                PopupAnimation="Fade"
                                StaysOpen="False">
                                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.12" Color="Black"/>
                                    </Border.Effect>
                                    <Calendar x:Name="PART_Calendar" BorderThickness="0"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DatePickerTextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0" Focusable="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Header -->
        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,20" VerticalAlignment="Top" Height="95">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="➕ Tạo Bài Kiểm Tra Mới" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4"/>
                    <TextBlock Text="Thiết lập và tạo bài kiểm tra cho lớp học của bạn" FontSize="12" Foreground="#64748B"/>
                </StackPanel>

                <Button x:Name="BtnBack" Grid.Column="1" Content="← Quay Lại" Background="White" Foreground="#475569" BorderBrush="#E2E8F0" BorderThickness="1" Padding="14,10" Cursor="Hand" Click="BtnBack_Click" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid VerticalAlignment="Stretch" Margin="24,100,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="480"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Preview Card -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                <TextBlock Text="📋 Xem Trước" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" Foreground="#1E293B"/>

                <Viewbox Width="480" HorizontalAlignment="Left" Stretch="Uniform">
                    <local:ExamCardView x:Name="PreviewExamCard" Width="400" />
                </Viewbox>
            </StackPanel>

        <!-- RIGHT: Form -->
        <Border Grid.Column="2" Background="White" CornerRadius="20" Padding="40">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.08" Color="#1E293B"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Section 1: Class Selection -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="🎓" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="CHỌN LỚP HỌC" Style="{StaticResource SectionHeaderStyle}" Margin="0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ComboBox x:Name="CbClass" Style="{StaticResource ModernComboBox}" Margin="0,0,0,8" SelectionChanged="CbClass_SelectionChanged"/>
                    <TextBlock x:Name="TxtClassInfo" FontSize="12" Foreground="#10B981" Margin="4,0,0,24" TextWrapping="Wrap" FontWeight="SemiBold"/>

                    <!-- Section 2: Basic Info -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="📝" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="THÔNG TIN CO BẢN" Style="{StaticResource SectionHeaderStyle}" Margin="0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Tên bài thi" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="TxtTitle" Style="{StaticResource ModernTextBox}" Height="46" Margin="0,0,0,20" TextChanged="Sync_UI" Tag="VD: Kiểm tra giữa kỳ..."/>

                    <TextBlock Text="Mô tả chi tiết" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="TxtDescription" Style="{StaticResource ModernTextBox}" Height="100" Margin="0,0,0,24" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" TextChanged="Sync_UI"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="ChkHasDeadline" Content="⏰ Có hạn chót nộp bài (Deadline)" Style="{StaticResource ModernCheckBoxStyle}" IsChecked="False" Checked="ChkHasDeadline_Changed" Unchecked="ChkHasDeadline_Changed"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelDeadline" Visibility="Collapsed" Margin="28,0,0,24">
                        <TextBlock Text="Chọn ngày và giờ kết thúc:" Style="{StaticResource FieldLabelStyle}" Foreground="#64748B" FontSize="12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <DatePicker x:Name="DpDeadlineDate" Grid.Column="0" Style="{StaticResource ModernDatePicker}" SelectedDateChanged="Sync_UI_Date"/>
                            <ComboBox x:Name="CbDeadlineTime" Grid.Column="2" Height="42" FontSize="13" IsEditable="True" Padding="12,0" VerticalContentAlignment="Center" BorderBrush="#E2E8F0" SelectionChanged="Sync_UI_Selection">
                                <ComboBoxItem Content="23:59" IsSelected="True"/>
                                <ComboBoxItem Content="12:00"/>
                                <ComboBoxItem Content="17:00"/>
                                <ComboBoxItem Content="00:00"/>
                            </ComboBox>
                        </Grid>
                        <TextBlock x:Name="TxtDeadlineWarning" Text="⚠️ Hạn chót phải sau thời điểm hiện tại!" FontSize="11" Foreground="#EF4444" Margin="4,6,0,0" Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Section 3: Configuration -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="⚙️" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="CẤU HÌNH BÀI THI" Style="{StaticResource SectionHeaderStyle}" Margin="0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Thời gian (phút)" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="CbTimeLimit" Style="{StaticResource ModernComboBox}" SelectionChanged="Sync_UI_Selection">
                                <ComboBoxItem Content="15"/>
                                <ComboBoxItem Content="30"/>
                                <ComboBoxItem Content="45"/>
                                <ComboBoxItem Content="60" IsSelected="True"/>
                                <ComboBoxItem Content="90"/>
                                <ComboBoxItem Content="120"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Điểm qua (%)" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="CbPassingScore" Style="{StaticResource ModernComboBox}" SelectionChanged="Sync_UI_Selection">
                                <ComboBoxItem Content="40%"/>
                                <ComboBoxItem Content="50%" IsSelected="True"/>
                                <ComboBoxItem Content="60%"/>
                                <ComboBoxItem Content="70%"/>
                                <ComboBoxItem Content="80%"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Question count removed as per request - will be calculated automatically -->

                    <!-- Section 4: Advanced Settings -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="🔧" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="CÀI ĐẶT NÂNG CAO" Style="{StaticResource SectionHeaderStyle}" Margin="0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#F8FAFC" CornerRadius="16" Padding="20" Margin="0,0,0,32" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <CheckBox x:Name="ChkPublished" Content="✅ Công bố bài thi ngay sau khi tạo" Style="{StaticResource ModernCheckBoxStyle}" IsChecked="False" Checked="Sync_UI_Toggle" Unchecked="Sync_UI_Toggle"/>
                            <CheckBox x:Name="ChkAllowReview" Content="👁️ Cho phép học sinh xem lại đáp án" Style="{StaticResource ModernCheckBoxStyle}" IsChecked="True" Checked="Sync_UI_Toggle" Unchecked="Sync_UI_Toggle"/>
                            <CheckBox x:Name="ChkRandomize" Content="🔀 Xáo trộn thứ tự câu hỏi cho mỗi lượt thi" Style="{StaticResource ModernCheckBoxStyle}" IsChecked="False" Checked="Sync_UI_Toggle" Unchecked="Sync_UI_Toggle"/>
                            <CheckBox x:Name="ChkShowScore" Content="📊 Hiển thị diểm số ngay khi nộp bài" Style="{StaticResource ModernCheckBoxStyle}" IsChecked="True" Checked="Sync_UI_Toggle" Unchecked="Sync_UI_Toggle"/>
                            <CheckBox x:Name="ChkMultipleAttempts" Content="🔁 Cho phép học sinh thực hiện nhiều lần" Style="{StaticResource ModernCheckBoxStyle}" IsChecked="True" Checked="ChkMultipleAttempts_Changed" Unchecked="ChkMultipleAttempts_Changed"/>

                            <StackPanel x:Name="PanelMaxAttempts" Margin="30,0,0,10">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Số lần làm tối da" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                                    <TextBlock Text=" (1-10)" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                                <TextBox x:Name="TxtMaxAttempts" Style="{StaticResource ModernTextBox}" Width="100" HorizontalAlignment="Left" Text="3" TextChanged="Sync_UI"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="BtnSubmit" Content="Tiếp theo: Soạn câu hỏi ➔" Height="54" Background="#3B82F6" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnSubmit_Click" FontSize="15">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="14">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2" Color="#3B82F6"/>
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                                            <Setter TargetName="border" Property="Margin" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="2" x:Name="BtnCancel" Content="❌ Hủy" Height="54" Background="White" Foreground="#64748B" FontWeight="Bold" Cursor="Hand" Click="BtnCancel_Click" FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
        </Grid>
    </Grid>
</UserControl>