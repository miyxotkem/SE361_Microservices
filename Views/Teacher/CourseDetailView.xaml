                                                            <Border Background="Transparent">
                                                                <Path x:Name="IconPath" Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" Fill="#EF4444" Width="16" Height="16" Stretch="Uniform"/>
                                                            </Border>
                                                        </ControlTemplate>
