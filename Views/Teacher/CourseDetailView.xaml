                    <DropShadowEffect BlurRadius="30" ShadowDepth="-5" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="40,40,40,15">
                        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="18" Foreground="#64748B" Cursor="Hand" Click="CloseAssignmentDetail_Click"/>
                        <TextBlock x:Name="DetailAssignTitle" FontSize="30" FontWeight="Bold" Foreground="#1E293B" Margin="0,10,0,10" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="⏱ Hạn nộp: " FontSize="14" Foreground="#64748B" VerticalAlignment="Center"/>
                            <Border x:Name="DetailAssignDeadlineBorder" Background="#ECFDF5" Padding="8,4" CornerRadius="6" BorderBrush="#A7F3D0" BorderThickness="1">
                                <TextBlock x:Name="DetailAssignDeadline" FontSize="14" Foreground="#10B981" FontWeight="SemiBold"/>
                            </Border>
