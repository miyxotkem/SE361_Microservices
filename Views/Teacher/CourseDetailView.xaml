                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button x:Name="BtnPublishGrades" Grid.Column="2" Content="Công khai diểm" Height="45" Background="White" Foreground="#F43F5E" BorderBrush="#F43F5E" BorderThickness="1.5" FontSize="15" FontWeight="SemiBold" Cursor="Hand" Click="BtnPublishGrades_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="StudentSubmitArea">
                                <Separator Margin="0,0,0,20" Background="#F1F5F9"/>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Nộp bài của bạn" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
