                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="40" Height="40" Background="#EFF6FF" CornerRadius="8" Margin="0,0,15,0">
                                                    <TextBlock Text="📎" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="Tài liệu đính kèm" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                    <TextBlock Text="Nhấn để xem hoặc tải xuống" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <StackPanel x:Name="InstructorManageArea" Visibility="Collapsed">
                                <Separator Margin="0,0,0,20" Background="#F1F5F9"/>
                                <TextBlock Text="Quản lý &amp; Chấm diểm" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,15"/>
                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="20">
                                    <StackPanel>
                                        <!-- Chip Notification cho Grading Status -->
                                        <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" Margin="0,0,0,15">
                                            <TextBlock x:Name="TxtInstructorGradingStatus" Text="Đang kiểm tra..." FontSize="13" Foreground="#F59E0B" FontWeight="SemiBold"/>
                                        </Border>

                                        <TextBlock x:Name="TxtSubmissionCount" Text="Đang tải dữ liệu..." FontSize="14" Foreground="#475569" Margin="0,0,0,15"/>
                                        <Button x:Name="BtnDownloadAll" Content="Tải về tất cả bài nộp (.zip)" Height="45" Background="#3B82F6" Foreground="White" FontSize="15" FontWeight="SemiBold" Cursor="Hand" Click="BtnDownloadAll_Click" Margin="0,0,0,10">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="BtnGradeAssignment" Grid.Column="0" Content="Chấm bài" Height="45" Background="White" Foreground="#8B5CF6" BorderBrush="#8B5CF6" BorderThickness="1.5" FontSize="15" FontWeight="SemiBold" Cursor="Hand" Click="BtnGradeAssignment_Click">
