                                        <DataTemplate>
                                            <Border Padding="15,10" Background="Transparent" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="14" Foreground="#1E293B" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding DisplayFileName}" FontSize="12" Foreground="#64748B" TextTrimming="CharacterEllipsis" MaxWidth="220" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Ellipse Grid.Column="1" Width="12" Height="12" Fill="{Binding StatusColor}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Grid x:Name="GradingRightPanel" Grid.Column="1" Margin="30" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="TxtGradeStudentName" Text="Tên Sinh Viên" FontSize="24" FontWeight="Bold" Foreground="#1E293B" TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtGradeStatus" Text="Nộp đúng hạn" FontSize="14" FontWeight="SemiBold" Foreground="#10B981" Margin="0,5,0,20"/>

                                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,25">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="📄" FontSize="24" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <TextBlock x:Name="TxtGradeFileName" Grid.Column="1" Text="file_bai_tap.pdf" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="2" Content="Tải xuống" Background="#EFF6FF" Foreground="#3B82F6" FontWeight="SemiBold" Padding="15,8" BorderThickness="0" Cursor="Hand" Click="BtnDownloadCurrentGradeFile_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>

                                <TextBlock Text="Điểm số (0 - 10)" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="InputScore" Style="{StaticResource ModernTextBox}" FontSize="16" FontWeight="Bold" Padding="15,10" Width="120" HorizontalAlignment="Left" Margin="0,0,0,20"/>

                                <TextBlock Text="Nhận xét" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="InputComment" Style="{StaticResource ModernTextBox}" TextWrapping="Wrap" AcceptsReturn="True" Height="150" Padding="15" VerticalContentAlignment="Top"/>

                                <Button x:Name="BtnSaveAndNext" Content="Luu &amp; Tiếp tục" Height="45" Background="#3B82F6" Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,30,0,0" Cursor="Hand" Click="BtnSaveAndNext_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- DRAWER: Add Video -->
        <Grid x:Name="AddVideoDrawer" Visibility="Collapsed">
            <Border Background="#40000000" MouseLeftButtonDown="CloseAddVideoDrawer_Click"/>
            <Border Background="White" Width="450" HorizontalAlignment="Right" CornerRadius="20,0,0,20" BorderBrush="#CBD5E1" BorderThickness="1,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="-5" Opacity="0.1" Color="Black"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30">
                        <Grid Margin="0,0,0,30">
                            <TextBlock Text="Thêm Video Bài Giảng" FontSize="22" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                            <Button Content="✕" FontSize="18" Foreground="#94A3B8" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Cursor="Hand" Click="CloseAddVideoDrawer_Click"/>
                        </Grid>

                        <TextBlock Text="Tiêu đề video" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="InputVideoTitle" Style="{StaticResource ModernTextBox}" Height="42" Margin="0,0,0,20"/>

                        <TextBlock Text="Mô tả" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="InputVideoDesc" Style="{StaticResource ModernTextBox}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="12,10" Margin="0,0,0,20"/>

                        <TextBlock Text="Tệp Video (.mp4)" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid Height="100" Margin="0,0,0,20" Cursor="Hand" Background="#F8FAFC" MouseLeftButtonDown="BtnBrowseVideo_Click" AllowDrop="True" Drop="VideoDropZone_Drop">
                            <Rectangle Stroke="#3B82F6" StrokeThickness="2" StrokeDashArray="4 4" RadiusX="12" RadiusY="12" IsHitTestVisible="False"/>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock Text="🎥" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtSelectedVideoFile" Text="Kéo thả tệp vào đây hoặc nhấn để chọn" FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="350"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="BtnConfirmAddVideo" Content="Tải lên Video" Width="140" Height="42" Background="{Binding CourseAccentBrush, ElementName=Root}" Foreground="White" FontWeight="SemiBold" Cursor="Hand" Click="ConfirmAddVideo_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Hủy" Margin="15,0,0,0" Background="Transparent" Foreground="#64748B" BorderThickness="0" Cursor="Hand" Click="CloseAddVideoDrawer_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>