                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Hủy" Margin="15,0,0,0" Background="Transparent" Foreground="#64748B" BorderThickness="0" Click="CloseAddAssignmentDrawer_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- DRAWER: Assignment Detail & Submission -->
        <Grid x:Name="AssignmentDetailDrawer" Visibility="Collapsed">
