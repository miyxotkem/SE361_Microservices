                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnConfirmAddAssignment" Content="Tạo bài tập" Width="140" Height="42" Background="{Binding CourseAccentBrush, ElementName=Root}" Foreground="White" Click="ConfirmAddAssignment_Click">
