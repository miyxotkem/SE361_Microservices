                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="-5" Opacity="0.1" Color="Black"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="30,30,30,15">
                        <Grid>
                            <TextBlock Text="Danh sách sinh viên" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                            <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="18" Foreground="#64748B" Cursor="Hand" Click="CloseManageStudentsDrawer_Click"/>
                        </Grid>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="30,0,30,30" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Empty State hiển thị thông minh hon -->
                            <Border x:Name="TxtNoEnrolledStudents" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="30,40" Margin="0,20,0,0" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="📭" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="Lớp học trống" Foreground="#475569" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Chua có sinh viên nào tham gia." Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl x:Name="EnrolledStudentsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding FullName}" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Email}" FontSize="13" Foreground="#64748B" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <Button Grid.Column="1" Content="🗑️" Width="36" Height="36" Background="#FEF2F2" Foreground="#EF4444" FontWeight="Bold" FontSize="16" Cursor="Hand" Tag="{Binding RegistrationId}" Click="BtnRemoveStudent_Click" ToolTip="Xóa sinh viên khỏi lớp">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- DRAWER: Grading -->
        <Grid x:Name="GradingDrawer" Visibility="Collapsed">
            <Border Background="#40000000" MouseLeftButtonDown="CloseGradingDrawer_Click"/>
            <Border HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="#F8FAFC" Width="800" CornerRadius="20,0,0,20" BorderBrush="#CBD5E1" BorderThickness="1,0,0,0">
