                                        <!-- Cải thiện hiển thị trạng thái bằng Border Chip -->
                                        <Border x:Name="DetailSubmissionStatusBorder" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="6" Padding="8,4">
                                            <TextBlock x:Name="DetailSubmissionStatus" Text="Chua nộp" FontSize="12" FontWeight="SemiBold" Foreground="#EF4444"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <Border x:Name="StudentGradePanel" Background="#ECFDF5" BorderBrush="#10B981" BorderThickness="1" CornerRadius="10" Padding="15,10" Margin="0,0,0,15" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="Kết quả chấm diểm" FontSize="16" FontWeight="Bold" Foreground="#10B981" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <TextBlock Text="Điểm số: " FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                            <TextBlock x:Name="TxtStudentScore" Text="10/10" FontSize="14" FontWeight="Bold" Foreground="#10B981"/>
                                        </StackPanel>
                                        <TextBlock Text="Nhận xét:" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,5,0,2"/>
                                        <TextBlock x:Name="TxtStudentComment" Text="Bài làm rất tốt!" FontSize="14" Foreground="#475569" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="SubmittedFileDetailsPanel" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,15" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="📄" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="TxtSubmittedFileName" Text="filename.pdf" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="TxtSubmittedTime" Text="Đã nộp lúc: 10:17 20/04/2026" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid x:Name="DropZoneGrid" Height="100" Margin="0,0,0,15" Cursor="Hand" Background="#F8FAFC" MouseLeftButtonDown="DropZone_Click" AllowDrop="True" Drop="DropZone_Drop">
                                    <Rectangle x:Name="DropZoneBorder" Stroke="#3B82F6" StrokeThickness="2" StrokeDashArray="4 4" RadiusX="12" RadiusY="12" IsHitTestVisible="False"/>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock Text="📁" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="TxtSelectedFile" Text="Kéo thả tệp vào đây hoặc nhấn để chọn" FontSize="14" Foreground="#64748B" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <Button x:Name="BtnDetailSubmit" Content="Tải lên tệp bài làm" Height="45" Background="#3B82F6" Foreground="White" FontSize="15" FontWeight="SemiBold" Cursor="Hand" Click="BtnSubmitAssignment_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBlock x:Name="TxtFormatHint" Text="Định dạng hỗ trợ: PDF, Word, Excel, ZIP..." FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- DRAWER: Approval List -->
        <Grid x:Name="ApprovalDrawer" Visibility="Collapsed">
            <Border Background="#40000000" MouseLeftButtonDown="CloseApprovalDrawer_Click"/>
            <Border HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="White" Width="500" CornerRadius="20,0,0,20" BorderBrush="#CBD5E1" BorderThickness="1,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="-5" Opacity="0.1" Color="Black"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="30,30,30,15">
                        <Grid>
                            <TextBlock Text="Yêu cầu chờ duyệt" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                            <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="18" Foreground="#64748B" Cursor="Hand" Click="CloseApprovalDrawer_Click"/>
                        </Grid>

                        <Button x:Name="BtnAcceptAll" Content="Duyệt tất cả" Height="40" Background="{Binding CourseAccentBrush, ElementName=Root}" Foreground="White" FontWeight="SemiBold" Margin="0,15,0,0" Cursor="Hand" Click="BtnAcceptAll_Click" Visibility="Collapsed">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="30,0,30,30" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Empty State hiển thị thông minh hon -->
                            <Border x:Name="TxtNoPendingRequests" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="30,40" Margin="0,20,0,0" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="📭" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="Không có yêu cầu chờ duyệt" Foreground="#475569" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Mọi thứ đã được xử lý xong." Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl x:Name="PendingRequestsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding FullName}" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding Email}" FontSize="13" Foreground="#64748B" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text=" • " FontSize="13" Foreground="#CBD5E1"/>
                                                        <TextBlock Text="{Binding TimeAgo}" FontSize="13" Foreground="#94A3B8" FontStyle="Italic"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Button Grid.Column="1" Content="✔" Width="36" Height="36" Background="#10B981" Foreground="White" FontWeight="Bold" Cursor="Hand" Margin="0,0,8,0" Tag="{Binding RegistrationId}" Click="BtnAcceptStudent_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <Button Grid.Column="2" Content="✕" Width="36" Height="36" Background="#EF4444" Foreground="White" FontWeight="Bold" Cursor="Hand" Tag="{Binding RegistrationId}" Click="BtnRejectStudent_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

