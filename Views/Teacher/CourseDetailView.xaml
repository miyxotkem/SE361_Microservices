                                <TextBlock x:Name="TxtAssignSelectedFile" Text="Kéo thả tệp vào đây hoặc nhấn để chọn" FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="350"/>
