<UserControl x:Class="e_learning_app.Views.StudentQuizView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">

    <UserControl.Resources>
        <!-- Radio Button hiện đại -->
        <Style x:Key="AnswerRadioBtn" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="AnswerBd" CornerRadius="14" Padding="18,14"
                                BorderBrush="#E2E8F0" BorderThickness="2" Background="White"
                                Margin="0,0,0,10" Cursor="Hand">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.04" Color="Black"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Circle indicator -->
                                <Border x:Name="CircleBd" Width="28" Height="28" CornerRadius="14"
                                        BorderBrush="#CBD5E1" BorderThickness="2" Background="White">
                                    <Border x:Name="InnerCircle" Width="12" Height="12" CornerRadius="6"
                                            Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ContentPresenter Grid.Column="2" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="AnswerBd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="AnswerBd" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="CircleBd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="CircleBd" Property="Background" Value="#3B82F6"/>
                                <Setter TargetName="InnerCircle" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AnswerBd" Property="BorderBrush" Value="#93C5FD"/>
                                <Setter TargetName="AnswerBd" Property="Background" Value="#F8FBFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nav Button -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Question Map Mini Button -->
        <Style x:Key="QMapBtn" TargetType="Button">
            <Setter Property="Width"           Value="34"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Margin"          Value="3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- MAIN QUIZ AREA -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR: Timer + Progress -->
            <Border Grid.Row="0" Background="White" Padding="24,16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Quiz info -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="📝  Bài kiểm tra giữa kỳ – Toán cao cấp A1" FontSize="15" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Câu 7 / 15  ·  15 điểm" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Timer (Subtle, centered) -->
                    <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="16" Padding="22,10" HorizontalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏱" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTimer" Text="  22:45" FontSize="22" FontWeight="Bold"
                                       Foreground="#1E293B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Overall progress bar -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="Tiến độ làm bài" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                        <Border Height="8" CornerRadius="4" Background="#E2E8F0" Width="180">
                            <Border HorizontalAlignment="Left" Width="84" Height="8" CornerRadius="4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#8B5CF6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>
                        <TextBlock Text="7/15 câu" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- QUESTION AREA -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="40,32,40,20">
                    <!-- Question number badge -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Background="#3B82F6" CornerRadius="10" Padding="12,6">
                            <TextBlock Text="Câu 7" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <Border Background="#EFF6FF" CornerRadius="10" Padding="10,6" Margin="8,0,0,0">
                            <TextBlock Text="Bắt buộc" FontSize="12" Foreground="#3B82F6" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Question text -->
                    <Border Background="White" CornerRadius="18" Padding="28,24" Margin="0,0,0,28">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" FontSize="18" FontWeight="SemiBold" Foreground="#1E293B" LineHeight="28">
                                Cho hàm số f(x) = x³ – 3x² + 2. Tìm tất cả các điểm cực trị của hàm số và phân loại chúng (cực đại / cực tiểu).
                            </TextBlock>
                            <!-- Hint / formula area -->
                            <Border Background="#F8FAFC" CornerRadius="12" Padding="16,12" Margin="0,16,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💡" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Gợi ý: Tìm f'(x) = 0, sau đó xét dấu f''(x) tại các nghiệm."
                                               FontSize="13" Foreground="#64748B" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Answer Options -->
                    <RadioButton Style="{StaticResource AnswerRadioBtn}" GroupName="Q7">
                        <TextBlock FontSize="15" Foreground="#1E293B">
                            <Run FontWeight="Bold" Foreground="#3B82F6">A. </Run>
                            <Run>Cực tiểu tại x = 0 (f(0) = 2) và cực đại tại x = 2 (f(2) = –2)</Run>
                        </TextBlock>
                    </RadioButton>

                    <RadioButton Style="{StaticResource AnswerRadioBtn}" GroupName="Q7" IsChecked="True">
                        <TextBlock FontSize="15" Foreground="#1E293B">
                            <Run FontWeight="Bold" Foreground="#3B82F6">B. </Run>
                            <Run>Cực đại tại x = 0 (f(0) = 2) và cực tiểu tại x = 2 (f(2) = –2)</Run>
                        </TextBlock>
                    </RadioButton>

                    <RadioButton Style="{StaticResource AnswerRadioBtn}" GroupName="Q7">
                        <TextBlock FontSize="15" Foreground="#1E293B">
                            <Run FontWeight="Bold" Foreground="#3B82F6">C. </Run>
                            <Run>Hàm số không có cực trị vì f'(x) luôn dương</Run>
                        </TextBlock>
                    </RadioButton>

                    <RadioButton Style="{StaticResource AnswerRadioBtn}" GroupName="Q7">
                        <TextBlock FontSize="15" Foreground="#1E293B">
                            <Run FontWeight="Bold" Foreground="#3B82F6">D. </Run>
                            <Run>Cực tiểu tại x = 0 và cực tiểu tại x = 2 (cùng loại)</Run>
                        </TextBlock>
                    </RadioButton>
                </StackPanel>
            </ScrollViewer>

            <!-- BOTTOM NAV BUTTONS -->
            <Border Grid.Row="2" Background="White" Padding="30,16" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Previous -->
                    <Button Grid.Column="0" Style="{StaticResource NavBtn}"
                            Content="← Câu trước" Background="#F1F5F9" Foreground="#64748B"/>

                    <!-- Mark for review -->
                    <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#FFFBF0" CornerRadius="10" Padding="14,7" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚩" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="  Đánh dấu xem lại" FontSize="12" Foreground="#CA8A04" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Next + Submit -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource NavBtn}"
                                Content="Câu tiếp theo →" Background="#EFF6FF" Foreground="#3B82F6"
                                Margin="0,0,10,0"/>
                        <Button Style="{StaticResource NavBtn}"
                                Content="🏁  Nộp bài" Background="#3B82F6" Foreground="White">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.2" Color="#3B82F6"/>
                            </Button.Effect>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- RIGHT PANEL: Question Map -->
        <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Map Header -->
                <Border Grid.Row="0" Padding="18,16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="🗺️  Bản đồ câu hỏi" FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Border CornerRadius="6" Background="#DCFCE7" Padding="8,4" Margin="0,0,6,0">
                                <TextBlock Text="✓ Đã làm" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                            </Border>
                            <Border CornerRadius="6" Background="#FEE2E2" Padding="8,4" Margin="0,0,6,0">
                                <TextBlock Text="🚩 Xem lại" FontSize="11" Foreground="#DC2626" FontWeight="SemiBold"/>
                            </Border>
                            <Border CornerRadius="6" Background="#F1F5F9" Padding="8,4">
                                <TextBlock Text="○ Chưa làm" FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Question Grid Map -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <WrapPanel Margin="14,14,14,8" Orientation="Horizontal">
                        <!-- Done questions (1-6) -->
                        <Button Style="{StaticResource QMapBtn}" Background="#DCFCE7" Foreground="#16A34A" Content="1" FontWeight="Bold"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#DCFCE7" Foreground="#16A34A" Content="2" FontWeight="Bold"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#DCFCE7" Foreground="#16A34A" Content="3" FontWeight="Bold"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#DCFCE7" Foreground="#16A34A" Content="4" FontWeight="Bold"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#FEF9C3" Foreground="#CA8A04" Content="5" FontWeight="Bold"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#DCFCE7" Foreground="#16A34A" Content="6" FontWeight="Bold"/>
                        <!-- Current -->
                        <Button Style="{StaticResource QMapBtn}" Width="38" Height="38" Margin="3"
                                Content="7" FontWeight="Bold" Foreground="White">
                            <Button.Background>
                                <SolidColorBrush Color="#3B82F6"/>
                            </Button.Background>
                        </Button>
                        <!-- Not done (8-15) -->
                        <Button Style="{StaticResource QMapBtn}" Background="#F1F5F9" Foreground="#94A3B8" Content="8"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#FEE2E2" Foreground="#DC2626" Content="9" FontWeight="Bold"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#F1F5F9" Foreground="#94A3B8" Content="10"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#F1F5F9" Foreground="#94A3B8" Content="11"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#F1F5F9" Foreground="#94A3B8" Content="12"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#F1F5F9" Foreground="#94A3B8" Content="13"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#F1F5F9" Foreground="#94A3B8" Content="14"/>
                        <Button Style="{StaticResource QMapBtn}" Background="#F1F5F9" Foreground="#94A3B8" Content="15"/>
                    </WrapPanel>
                </ScrollViewer>

                <!-- Summary Stats -->
                <Border Grid.Row="2" Padding="18,14" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Đã làm" FontSize="12" Foreground="#64748B"/>
                            <TextBlock Text="6 / 15" FontSize="12" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Đánh dấu xem lại" FontSize="12" Foreground="#64748B"/>
                            <TextBlock Text="2 câu" FontSize="12" FontWeight="Bold" Foreground="#CA8A04" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Chưa làm" FontSize="12" Foreground="#64748B"/>
                            <TextBlock Text="7 câu" FontSize="12" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Right"/>
                        </Grid>

                        <Button Margin="0,14,0,0" Background="#DC2626" Foreground="White" FontWeight="Bold"
                                FontSize="13" Height="44" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="0,0,0,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="🏁  Nộp bài ngay" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
