<UserControl x:Class="e_learning_app.Views.StudentNotificationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <!-- Filter / Tab Button -->
        <Style x:Key="FilterTabBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Margin"     Value="0,0,10,0"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="12" Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Unread Notification Item Style -->
        <Style x:Key="NotifUnread" TargetType="Border">
            <Setter Property="Background"   Value="#EFF6FF"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding"      Value="18"/>
            <Setter Property="Margin"       Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.04" Color="#3B82F6"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Read Notification Item Style -->
        <Style x:Key="NotifRead" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding"      Value="18"/>
            <Setter Property="Margin"       Value="0,0,0,12"/>
            <Setter Property="BorderBrush"  Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,30,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="🔔  Thông báo của bạn" Style="{StaticResource SectionHeader}" FontSize="24"/>
                <TextBlock Text="Cập nhật mới nhất về lớp học và bài tập" FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" Content="✓ Đánh dấu đã đọc tất cả"
                    Background="Transparent" BorderThickness="0" Foreground="#3B82F6"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand" VerticalAlignment="Center"/>
        </Grid>

        <!-- TABS FILTER -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <RadioButton Content="Tất cả (5)" Style="{StaticResource FilterTabBtn}" IsChecked="True"/>
            <RadioButton Content="Chưa đọc (2)" Style="{StaticResource FilterTabBtn}"/>
            <RadioButton Content="Bài tập (1)" Style="{StaticResource FilterTabBtn}"/>
            <RadioButton Content="Cảnh báo (0)" Style="{StaticResource FilterTabBtn}"/>
        </StackPanel>

        <!-- LIST NOTIFICATIONS -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                
                <!-- UNREAD - Urgent (Deadline/Exam) -->
                <Border Style="{StaticResource NotifUnread}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Width="48" Height="48" CornerRadius="12" Background="#DBEAFE" VerticalAlignment="Top">
                            <TextBlock Text="🚨" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        
                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Sắp hết hạn: Bài tập Toán – Chương 3!" FontSize="15" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock Text="Vừa xong" FontSize="11" Foreground="#3B82F6" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Bạn còn chưa đầy 12 giờ để nộp bài tập Toán. Hãy cố gắng hoàn thành để giữ chuỗi streak nhé!" 
                                       FontSize="13" Foreground="#475569" TextWrapping="Wrap" LineHeight="20"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Background="#3B82F6" Foreground="White" FontWeight="SemiBold" FontSize="12" 
                                        BorderThickness="0" Padding="14,8" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <TextBlock Text="Làm bài ngay →"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- UNREAD - Teacher post -->
                <Border Style="{StaticResource NotifUnread}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="48" Height="48" CornerRadius="12" Background="#FFFBEB" VerticalAlignment="Top">
                            <TextBlock Text="📢" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Giảng viên đã thêm tài liệu mới" FontSize="15" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock Text="2 giờ trước" FontSize="11" Foreground="#3B82F6" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Thầy Nguyễn Văn An vừa tải lên 'Slide_Bai14_BoSung.pdf' trong khóa Toán cao cấp A1." 
                                       FontSize="13" Foreground="#475569" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- READ - Exam result -->
                <Border Style="{StaticResource NotifRead}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="48" Height="48" CornerRadius="12" Background="#F1F5F9" VerticalAlignment="Top">
                            <TextBlock Text="🏆" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Đã có điểm bài Quiz Vật lý Lab 1" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                                <TextBlock Text="Hôm qua" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Chúc mừng! Bạn đạt 9/10 điểm trong bài kiểm tra gần nhất. Bạn nhận được +250 XP." 
                                       FontSize="13" Foreground="#64748B" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- READ - System achievement -->
                <Border Style="{StaticResource NotifRead}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="48" Height="48" CornerRadius="12" Background="#F1F5F9" VerticalAlignment="Top">
                            <TextBlock Text="⭐" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Mở khóa cấp độ tiếp theo!" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                                <TextBlock Text="02/04/2026" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Bạn đã đạt Level 14. Tiếp tục duy trì phong độ để mở khóa thêm các huy hiệu độc quyền nhé." 
                                       FontSize="13" Foreground="#64748B" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- READ - Course enrollment -->
                <Border Style="{StaticResource NotifRead}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="48" Height="48" CornerRadius="12" Background="#F1F5F9" VerticalAlignment="Top">
                            <TextBlock Text="👋" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Chào mừng bạn đến với Lập trình Python cơ bản" FontSize="15" FontWeight="SemiBold" Foreground="#1E293B"/>
                                <TextBlock Text="30/03/2026" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Bạn đã tham gia thành công khóa học mới. Hãy xem video đầu tiên ngay." 
                                       FontSize="13" Foreground="#64748B" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
