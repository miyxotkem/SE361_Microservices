<UserControl x:Class="e_learning_app.Views.Admin.AdminUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="FilterPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding"      Value="16,6"/>
            <Setter Property="Margin"       Value="0,0,8,0"/>
            <Setter Property="Cursor"       Value="Hand"/>
        </Style>

        <Style x:Key="ActionIconBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="6"/>
            <Setter Property="FontSize"        Value="14"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,30,32,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== PAGE HEADER ===== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="👥  Quản lý Người dùng" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock x:Name="TxtUserCount" Text="Đang tải..." FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Add user button -->
            <Border Grid.Column="1" CornerRadius="12" Cursor="Hand" VerticalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#7C3AED" Offset="0"/>
                        <GradientStop Color="#4F46E5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Horizontal" Margin="18,10">
                    <TextBlock Text="+" FontSize="18" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="  Thêm người dùng" FontSize="13" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== SEARCH + FILTER BAR ===== -->
        <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="1" Opacity="0.06" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="10" Padding="14,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Foreground="#94A3B8"/>
                        <TextBox x:Name="TxtSearch" Grid.Column="1" Margin="8,0,0,0" Height="38"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="13" Foreground="#1E293B"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtSearch_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Tìm kiếm theo tên, email..."
                                                                       Foreground="#CBD5E1" FontSize="13"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Filter pills -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="FilterAll"     Style="{StaticResource FilterPill}" Background="#EDE9FE"
                            MouseLeftButtonUp="FilterAll_Click">
                        <TextBlock Text="Tất cả" FontSize="12" FontWeight="SemiBold" Foreground="#7C3AED"/>
                    </Border>
                    <Border x:Name="FilterStudent" Style="{StaticResource FilterPill}" Background="#F1F5F9"
                            MouseLeftButtonUp="FilterStudent_Click">
                        <TextBlock Text="Học viên" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                    </Border>
                    <Border x:Name="FilterTeacher" Style="{StaticResource FilterPill}" Background="#F1F5F9"
                            MouseLeftButtonUp="FilterTeacher_Click">
                        <TextBlock Text="Giảng viên" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== USER TABLE ===== -->
        <Border Grid.Row="4" Background="White" CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.06" Color="Black"/>
            </Border.Effect>
            <DataGrid x:Name="UsersGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      RowHeight="52"
                      ColumnHeaderHeight="44"
                      BorderThickness="0"
                      Background="White"
                      FontSize="13"
                      Foreground="#1E293B"
                      HeadersVisibility="Column">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"      Value="#F8FAFC"/>
                        <Setter Property="Foreground"      Value="#64748B"/>
                        <Setter Property="FontSize"        Value="11"/>
                        <Setter Property="FontWeight"      Value="Bold"/>
                        <Setter Property="Padding"         Value="20,0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Height"          Value="44"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="#1E293B"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F3FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EDE9FE"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness"   Value="0"/>
                        <Setter Property="Padding"           Value="20,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background"  Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <!-- Avatar + Name (template column) -->
                    <DataGridTemplateColumn Header="Người dùng" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                    <Border Width="34" Height="34" CornerRadius="10">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C3AED" Offset="0"/>
                                                <GradientStop Color="#4F46E5" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock x:Name="TxtInitial" Text="{Binding Initials}"
                                                   Foreground="White" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>
                                    </Border>
                                    <TextBlock Text="{Binding FullName}" Margin="10,0,0,0"
                                               FontWeight="SemiBold" FontSize="13" Foreground="#1E293B"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Email"    Binding="{Binding Email}"     Width="*"/>
                    <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt}" Width="130"/>

                    <!-- Role pill -->
                    <DataGridTemplateColumn Header="Vai trò" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="10,4" Margin="8,0" HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#EDE9FE"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="Instructor">
                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="Student">
                                                    <Setter Property="Background" Value="#DBEAFE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Role}" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#7C3AED"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="Instructor">
                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="Student">
                                                        <Setter Property="Foreground" Value="#3B82F6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Actions -->
                    <DataGridTemplateColumn Header="Thao tác" Width="230">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                                    <!-- Đổi role -->
                                    <Button x:Name="BtnChangeRole" Click="BtnChangeRole_Click" Margin="0,0,6,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#EDE9FE" CornerRadius="8" Padding="8,4" Cursor="Hand">
                                                    <TextBlock Text="✏️ Đổi vai trò" FontSize="11" Foreground="#7C3AED" FontWeight="SemiBold"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <!-- Khóa/Mở khóa -->
                                    <Button x:Name="BtnBlockUser" Click="BtnBlockUser_Click" Margin="0,0,6,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{Binding IsBlockedBrush}" CornerRadius="8" Padding="8,4" Cursor="Hand">
                                                    <TextBlock Text="{Binding BlockText}" FontSize="11" Foreground="{Binding BlockTextBrush}" FontWeight="SemiBold"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Xóa -->
                                    <Button x:Name="BtnDeleteUser" Click="BtnDeleteUser_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#FEE2E2" CornerRadius="8" Padding="8,4" Cursor="Hand">
                                                    <TextBlock Text="🗑️ Xóa" FontSize="11" Foreground="#DC2626" FontWeight="SemiBold"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
