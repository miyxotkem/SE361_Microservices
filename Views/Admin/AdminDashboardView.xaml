<UserControl x:Class="e_learning_app.Views.Admin.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <!-- Stat Card -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding"      Value="22,18"/>
            <Setter Property="Background"   Value="White"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.07" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin"     Value="0,0,0,14"/>
        </Style>

        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding"      Value="10,4"/>
        </Style>

        <!-- Action Button -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
        </Style>

        <!-- DataGrid style -->
        <Style x:Key="AdminGrid" TargetType="DataGrid">
            <Setter Property="Background"          Value="White"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F5F9"/>
            <Setter Property="RowHeight"           Value="46"/>
            <Setter Property="FontSize"            Value="13"/>
            <Setter Property="Foreground"          Value="#1E293B"/>
            <Setter Property="ColumnHeaderHeight"  Value="42"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows"      Value="False"/>
            <Setter Property="CanUserDeleteRows"   Value="False"/>
            <Setter Property="IsReadOnly"          Value="True"/>
            <Setter Property="SelectionMode"       Value="Single"/>
            <Setter Property="SelectionUnit"       Value="FullRow"/>
            <Setter Property="HeadersVisibility"   Value="Column"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,30,32,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TxtGreeting"
                               FontSize="24" FontWeight="Bold" Foreground="#1E293B"
                               Text="🛡️  Xin chào, Administrator!"/>
                    <TextBlock FontSize="13" Foreground="#64748B" Margin="0,6,0,0"
                               Text="Đây là tổng quan hệ thống EduFlow hôm nay"/>
                </StackPanel>

                <!-- Quick actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#EDE9FE" CornerRadius="12" Padding="14,10" Margin="0,0,10,0" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="  Thêm người dùng" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#7C3AED" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#F0FDF4" CornerRadius="12" Padding="14,10" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="  Xuất báo cáo" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#16A34A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ===== STAT CARDS (Row 2) ===== -->
            <UniformGrid Grid.Row="2" Rows="1" Columns="4">
                
                <!-- Tổng người dùng -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <Border Width="42" Height="42" CornerRadius="13" HorizontalAlignment="Left">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                    <GradientStop Color="#4F46E5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="👥" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtTotalUsers" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,8,0,0"/>
                        <TextBlock Text="Tổng người dùng" FontSize="12" Foreground="#64748B" Margin="0,4,0,4"/>
                        <Border Style="{StaticResource Pill}" Background="#EDE9FE" HorizontalAlignment="Left">
                            <TextBlock Text="▲ Đang hoạt động" FontSize="10" Foreground="#7C3AED" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Học viên -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <Border Width="42" Height="42" CornerRadius="13" Background="#EFF6FF" HorizontalAlignment="Left">
                            <TextBlock Text="🎓" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtTotalStudents" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,8,0,0"/>
                        <TextBlock Text="Học viên" FontSize="12" Foreground="#64748B" Margin="0,4,0,4"/>
                        <Border Style="{StaticResource Pill}" Background="#DBEAFE" HorizontalAlignment="Left">
                            <TextBlock Text="Student" FontSize="10" Foreground="#3B82F6" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Giảng viên -->
                <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <Border Width="42" Height="42" CornerRadius="13" Background="#F0FDF4" HorizontalAlignment="Left">
                            <TextBlock Text="🧑‍🏫" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtTotalTeachers" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,8,0,0"/>
                        <TextBlock Text="Giảng viên" FontSize="12" Foreground="#64748B" Margin="0,4,0,4"/>
                        <Border Style="{StaticResource Pill}" Background="#DCFCE7" HorizontalAlignment="Left">
                            <TextBlock Text="Teacher" FontSize="10" Foreground="#16A34A" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Đăng ký mới (tuần) -->
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Border Width="42" Height="42" CornerRadius="13" Background="#FFF1F2" HorizontalAlignment="Left">
                            <TextBlock Text="🆕" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtNewUsers" Text="—" FontSize="30" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,8,0,0"/>
                        <TextBlock Text="Đăng ký tuần này" FontSize="12" Foreground="#64748B" Margin="0,4,0,4"/>
                        <Border Style="{StaticResource Pill}" Background="#FEE2E2" HorizontalAlignment="Left">
                            <TextBlock Text="🔥 Mới" FontSize="10" Foreground="#DC2626" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ===== ACTIVITY + QUICK ACTIONS (Row 4) ===== -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Recent users table -->
                <Border Grid.Column="0" Background="White" CornerRadius="18" Padding="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Table header -->
                        <Grid Grid.Row="0" Margin="20,16,20,12">
                            <TextBlock Text="👤  Người dùng mới dang ký" Style="{StaticResource SectionHeader}" Margin="0"/>
                            <TextBlock Text="Xem tất cả →" FontSize="12" Foreground="#7C3AED" FontWeight="SemiBold"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                        </Grid>

                        <DataGrid Grid.Row="1" x:Name="RecentUsersGrid" Style="{StaticResource AdminGrid}"
                                  Margin="0,0,0,8">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"   Value="#F8FAFC"/>
                                    <Setter Property="Foreground"   Value="#64748B"/>
                                    <Setter Property="FontSize"     Value="11"/>
                                    <Setter Property="FontWeight"   Value="Bold"/>
                                    <Setter Property="Padding"      Value="20,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Foreground" Value="#1E293B"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F5F3FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EDE9FE"/>
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding"         Value="20,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Họ và tên"  Binding="{Binding FullName}"  Width="180"/>
                                <DataGridTextColumn Header="Email"       Binding="{Binding Email}"     Width="*"/>
                                <DataGridTextColumn Header="Vai trò"     Binding="{Binding Role}"      Width="110"/>
                                <DataGridTextColumn Header="Ngày tạo"   Binding="{Binding CreatedAt}"  Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- RIGHT: Quick action cards -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="⚡  Thao tác nhanh" Style="{StaticResource SectionHeader}"/>

                    <!-- Action: Duyệt Teacher -->
                    <Border Background="White" CornerRadius="16" Padding="18,14" Margin="0,0,0,12" Cursor="Hand">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="1" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="12" Background="#EDE9FE">
                                <TextBlock Text="✅" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Duyệt tài khoản Giảng viên" FontWeight="SemiBold" FontSize="13"
                                           Foreground="#1E293B"/>
                                <TextBlock x:Name="TxtPendingTeachers" Text="0 yêu cầu dang chờ"
                                           FontSize="11" Foreground="#64748B" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="2" Background="#EDE9FE" CornerRadius="8" Padding="8,4"
                                    VerticalAlignment="Center">
                                <TextBlock Text="→" Foreground="#7C3AED" FontWeight="Bold" FontSize="14"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Action: Khóa tài khoản -->
                    <Border Background="White" CornerRadius="16" Padding="18,14" Margin="0,0,0,12" Cursor="Hand">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="1" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="12" Background="#FEE2E2">
                                <TextBlock Text="🔒" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Quản lý tài khoản vi phạm" FontWeight="SemiBold" FontSize="13"
                                           Foreground="#1E293B"/>
                                <TextBlock x:Name="TxtBannedUsers" Text="0 tài khoản bị khóa"
                                           FontSize="11" Foreground="#64748B" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="2" Background="#FEE2E2" CornerRadius="8" Padding="8,4"
                                    VerticalAlignment="Center">
                                <TextBlock Text="→" Foreground="#DC2626" FontWeight="Bold" FontSize="14"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Action: Reset mật khẩu -->
                    <Border Background="White" CornerRadius="16" Padding="18,14" Margin="0,0,0,12" Cursor="Hand">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="1" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="12" Background="#FEF9C3">
                                <TextBlock Text="🔑" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Đặt lại mật khẩu người dùng" FontWeight="SemiBold" FontSize="13"
                                           Foreground="#1E293B"/>
                                <TextBlock Text="Hỗ trợ khi người dùng bị khoá"
                                           FontSize="11" Foreground="#64748B" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="2" Background="#FEF9C3" CornerRadius="8" Padding="8,4"
                                    VerticalAlignment="Center">
                                <TextBlock Text="→" Foreground="#CA8A04" FontWeight="Bold" FontSize="14"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- System Status -->
                    <TextBlock Text="📡  Trạng thái hệ thống" Style="{StaticResource SectionHeader}" Margin="0,8,0,14"/>
                    <Border Background="White" CornerRadius="16" Padding="18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="1" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Firebase -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔥" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Firebase / Firestore" FontSize="13" Foreground="#1E293B"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#DCFCE7" CornerRadius="8" Padding="8,3">
                                    <TextBlock Text="● Online" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                            <!-- Auth -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔐" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Firebase Auth" FontSize="13" Foreground="#1E293B"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#DCFCE7" CornerRadius="8" Padding="8,3">
                                    <TextBlock Text="● Online" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                            <!-- Storage -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗄️" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Cloud Storage" FontSize="13" Foreground="#1E293B"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#FEF9C3" CornerRadius="8" Padding="8,3">
                                    <TextBlock Text="● Giới hạn" FontSize="11" Foreground="#CA8A04" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
