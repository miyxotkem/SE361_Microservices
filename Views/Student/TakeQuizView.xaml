<UserControl x:Class="e_learning_app.Views.TakeQuizView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">

    <UserControl.Resources>
        <!-- Radio Button hiện đại -->
        <Style x:Key="AnswerRadioBtn" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="AnswerBd" CornerRadius="16" Padding="20,16"
                                BorderBrush="#E2E8F0" BorderThickness="1.5" Background="White"
                                Margin="0,0,0,12" Cursor="Hand"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.04" Color="Black"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Circle indicator / Checkmark -->
                                <Border x:Name="CircleBd" Width="24" Height="24" CornerRadius="12"
                                        BorderBrush="#CBD5E1" BorderThickness="2" Background="White" HorizontalAlignment="Left">
                                    <TextBlock x:Name="CheckIcon" Text="✓" Foreground="White" FontSize="14" FontWeight="Bold" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Margin="0,-2,0,0"/>
                                </Border>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="AnswerBd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="AnswerBd" Property="Background" Value="#F0F7FF"/>
                                <Setter TargetName="CircleBd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="CircleBd" Property="Background" Value="#3B82F6"/>
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AnswerBd" Property="BorderBrush" Value="#93C5FD"/>
                                <Setter TargetName="AnswerBd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                            <!-- Hover lift animation -->
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AnswerBd" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="AnswerBd" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.01" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AnswerBd" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="AnswerBd" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nav Button -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Question Map Mini Button -->
        <Style x:Key="QMapBtn" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Margin"          Value="6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="20"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280" x:Name="ColumnRightPanel"/>
        </Grid.ColumnDefinitions>

        <!-- MAIN QUIZ AREA -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR: Timer + Progress -->
            <Border Grid.Row="0" Background="White" Padding="24,16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Quiz info -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtQuizTitle" Text="📝  Đang tải bài thi..." FontSize="15" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock x:Name="TxtProgressHeader" Text="Câu -- / --  ·  -- diểm" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Timer (Prominent, centered) -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Background="#F8FAFC" CornerRadius="16" Padding="22,8" HorizontalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="Black"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏱" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtTimer" Text="00:00:00" FontSize="24" FontWeight="Bold"
                                           Foreground="#1E293B" VerticalAlignment="Center" FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                        <!-- Time Progress Bar -->
                        <Border Height="4" Background="#F1F5F9" CornerRadius="2" Width="140" Margin="0,6,0,0">
                            <Border x:Name="TimeProgressFill" HorizontalAlignment="Left" Background="#3B82F6" Width="140" Height="4" CornerRadius="2"/>
                        </Border>
                    </StackPanel>

                    <!-- Right Area: Progress Bar -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Overall progress bar -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Tiến độ làm bài" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                            <Border Height="8" CornerRadius="4" Background="#E2E8F0" Width="180">
                                <Border x:Name="ProgressBarFill" HorizontalAlignment="Left" Width="0" Height="8" CornerRadius="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                            <TextBlock x:Name="TxtProgressFooter" Text="0/0 câu" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- QUESTION AREA -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="MainContentContainer" Margin="40,32,40,20">
                    <!-- Question number badge -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Border Background="#3B82F6" CornerRadius="10" Padding="12,6">
                            <TextBlock x:Name="TxtQuestionBadge" Text="Câu --" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <Border x:Name="BadgeRequired" Background="#EFF6FF" CornerRadius="10" Padding="10,6" Margin="8,0,0,0">
                            <TextBlock Text="Bắt buộc" FontSize="12" Foreground="#3B82F6" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Question text -->
                    <Border Background="White" CornerRadius="18" Padding="28,24" Margin="0,0,0,28">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock x:Name="TxtQuestionContent" TextWrapping="Wrap" FontSize="20" FontWeight="Medium" Foreground="#0F172A" LineHeight="30">
                                Đang tải câu hỏi...
                            </TextBlock>
                            <!-- Hint / formula area -->
                            <Border x:Name="BorderHint" Background="#F8FAFC" CornerRadius="12" Padding="16,12" Margin="0,16,0,0" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💡" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtHint" Text="  Gợi ý sẽ hiển thị ở đây."
                                               FontSize="13" Foreground="#64748B" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Answer Options Container -->
                    <StackPanel x:Name="PanelAnswers">
                        <!-- Items will be generated dynamically -->
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- BOTTOM NAV BUTTONS -->
            <Border Grid.Row="2" Background="White" Padding="30,16" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Previous -->
                    <Button Grid.Column="0" x:Name="BtnPrev" Style="{StaticResource NavBtn}" Click="BtnPrev_Click"
                            Content="← Câu trước" Background="#F1F5F9" Foreground="#64748B"/>

                    <!-- Mark for review -->
                    <ToggleButton Grid.Column="1" x:Name="BtnMarkReview" HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Background="Transparent" BorderThickness="1" BorderBrush="#FCD34D"
                                  Padding="14,7" Cursor="Hand" Click="BtnMarkReview_Click">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#FEF9C3"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#F59E0B"/>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter TargetName="Bd" Property="Background" Value="#FFFBF0"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FDE68A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚩" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="  Đánh dấu xem lại" FontSize="12" Foreground="#D97706" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- Next -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnNext" Style="{StaticResource NavBtn}" Click="BtnNext_Click"
                                Content="Câu tiếp theo →" Background="#EFF6FF" Foreground="#3B82F6"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- FLOATING EDGE BUTTON -->
        <Button x:Name="BtnFloatingToggle" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" 
                Click="BtnToggleMap_Click" Cursor="Hand" Width="24" Height="64" Panel.ZIndex="10" Margin="0,0,-1,0"
                Background="#F1F5F9" Foreground="#94A3B8" Content="⯈">
            <Button.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0" Color="Black"/>
            </Button.Effect>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="#E2E8F0" BorderThickness="1,1,0,1" CornerRadius="8,0,0,8">
                        <TextBlock Text="{TemplateBinding Content}" FontSize="12" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E2E8F0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- RIGHT PANEL: Question Map -->
        <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Map Header -->
                <Border Grid.Row="0" Padding="18,16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="🗺️  Bản đồ câu hỏi" FontSize="14" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel x:Name="PanelMapLegends" Orientation="Horizontal" Margin="0,10,0,0">
                            <Border CornerRadius="6" Background="#DCFCE7" Padding="8,4" Margin="0,0,6,0">
                                <TextBlock Text="✓ Đã làm" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                            </Border>
                            <Border CornerRadius="6" Background="#FEF9C3" Padding="8,4" Margin="0,0,6,0">
                                <TextBlock Text="🚩 Xem lại" FontSize="11" Foreground="#D97706" FontWeight="SemiBold"/>
                            </Border>
                            <Border CornerRadius="6" Background="#F1F5F9" Padding="8,4">
                                <TextBlock Text="○ Chua làm" FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Question Grid Map -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="PanelQuestionMap" Margin="14,14,14,8" Orientation="Horizontal">
                        <!-- Will be generated dynamically -->
                    </WrapPanel>
                </ScrollViewer>

                <!-- Summary Stats -->
                <Border Grid.Row="2" Padding="18,14" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Đã làm" FontSize="12" Foreground="#64748B"/>
                            <TextBlock x:Name="TxtStatsDone" Text="0 / --" FontSize="12" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Đánh dấu xem lại" FontSize="12" Foreground="#64748B"/>
                            <TextBlock x:Name="TxtStatsReview" Text="0 câu" FontSize="12" FontWeight="Bold" Foreground="#CA8A04" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Chua làm" FontSize="12" Foreground="#64748B"/>
                            <TextBlock x:Name="TxtStatsTodo" Text="-- câu" FontSize="12" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Save & Exit (sidebar) -->
                        <Button Margin="0,14,0,6" Height="40" BorderThickness="1" BorderBrush="#FDE68A"
                                Background="#FFFBF0" Cursor="Hand" Click="BtnSaveExit_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="  Lưu &amp; Thoát" FontSize="12" Foreground="#D97706" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Submit -->
                        <Button x:Name="BtnSubmitRight" Background="#DC2626" Foreground="White" FontWeight="Bold"
                                FontSize="13" Height="44" BorderThickness="0" Cursor="Hand" Click="BtnSubmit_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="0,0,0,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="🏁  Nộp bài ngay" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
