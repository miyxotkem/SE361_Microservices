<UserControl x:Class="e_learning_app.Views.StudentDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#F1F5F9"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.04" Color="#0F172A"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="PillLabel" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="40,30,40,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TxtGreeting" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock x:Name="TxtTodayInfo" FontSize="14" Foreground="#64748B" Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#EFF6FF" CornerRadius="12" Padding="14,10" Margin="0,0,10,0" Cursor="Hand" MouseLeftButtonDown="BtnQuickCourses_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📚" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="  Lịch lên lớp" FontSize="13" FontWeight="SemiBold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <UniformGrid Grid.Row="2" Columns="3" Rows="1">
                    <Border Style="{StaticResource ModernCard}" Margin="0,0,20,0" Padding="20">
                        <StackPanel>
                            <Border Width="48" Height="48" CornerRadius="14" Background="#EFF6FF" HorizontalAlignment="Left" Margin="0,0,0,16">
                                <TextBlock Text="👨‍🎓" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="TxtTotalCourses" FontSize="32" FontWeight="Bold" Foreground="#0F172A" Text="0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="Khóa dang học" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                <Border Style="{StaticResource PillLabel}" Background="#DCFCE7" Margin="10,0,0,0">
                                    <TextBlock Text="Đã duyệt" FontSize="11" Foreground="#16A34A" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ModernCard}" Margin="0,0,20,0" Padding="20">
                        <StackPanel>
                            <Border Width="48" Height="48" CornerRadius="14" Background="#FEF2F2" HorizontalAlignment="Left" Margin="0,0,0,16">
                                <TextBlock Text="📝" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="TxtPendingAssignments" FontSize="32" FontWeight="Bold" Foreground="#0F172A" Text="0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="Bài tập chờ nộp" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                <Border Style="{StaticResource PillLabel}" Background="#FEE2E2" Margin="10,0,0,0">
                                    <TextBlock Text="Cần xử lý" FontSize="11" Foreground="#DC2626" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ModernCard}" Padding="20">
                        <StackPanel>
                            <Border Width="48" Height="48" CornerRadius="14" Background="#F0FDF4" HorizontalAlignment="Left" Margin="0,0,0,16">
                                <TextBlock Text="📈" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="TxtAvgScore" FontSize="32" FontWeight="Bold" Foreground="#0F172A" Text="0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="Bài kiểm tra" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                <Border Style="{StaticResource PillLabel}" Background="#FFF7ED" Margin="10,0,0,0">
                                    <TextBlock Text="Chưa làm" FontSize="11" Foreground="#C2410C" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="📅  Lịch học hôm nay" Style="{StaticResource SectionHeader}" Margin="0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTodayDate" FontSize="13" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <ItemsControl x:Name="ScheduleItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,0,12" Tag="{Binding TargetCourse}" Click="BtnNavigateToCourse_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="HoverBorder" Style="{StaticResource ModernCard}" Padding="16">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="6"/>
                                                            <ColumnDefinition Width="16"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="{Binding ThemeBrush}" CornerRadius="3"/>
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding TitleDisplay}" FontWeight="Bold" FontSize="16" Foreground="#0F172A" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="⏰ " FontSize="13" Foreground="#94A3B8"/>
                                                                <TextBlock Text="{Binding TimeSlot}" FontSize="13" FontWeight="SemiBold" Foreground="#475569"/>
                                                                <TextBlock Text="   |   📍 " FontSize="13" Foreground="#CBD5E1"/>
                                                                <TextBlock Text="{Binding Room}" FontSize="13" Foreground="#64748B"/>
                                                                <TextBlock Text="   |   👨‍🏫 " FontSize="13" Foreground="#CBD5E1"/>
                                                                <TextBlock Text="{Binding InstructorName}" FontSize="13" Foreground="#64748B"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Border Grid.Column="3" Background="{Binding StatusBg}" CornerRadius="8" Padding="14,6" VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding Status}" FontSize="12" Foreground="{Binding StatusFg}" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="HoverBorder" Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,30,0,16">
                            <TextBlock Text="🗓️  Lịch học sắp tới" Style="{StaticResource SectionHeader}" Margin="0" VerticalAlignment="Center"/>
                        </Grid>

                        <ItemsControl x:Name="UpcomingScheduleItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,0,12" Tag="{Binding TargetCourse}" Click="BtnNavigateToCourse_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="HoverBorder" Style="{StaticResource ModernCard}" Padding="16">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="6"/>
                                                            <ColumnDefinition Width="16"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="{Binding ThemeBrush}" CornerRadius="3"/>
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding TitleDisplay}" FontWeight="Bold" FontSize="16" Foreground="#0F172A" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="⏰ " FontSize="13" Foreground="#94A3B8"/>
                                                                <TextBlock Text="{Binding TimeSlot}" FontSize="13" FontWeight="SemiBold" Foreground="#475569"/>
                                                                <TextBlock Text="   |   📍 " FontSize="13" Foreground="#CBD5E1"/>
                                                                <TextBlock Text="{Binding Room}" FontSize="13" Foreground="#64748B"/>
                                                                <TextBlock Text="   |   👨‍🏫 " FontSize="13" Foreground="#CBD5E1"/>
                                                                <TextBlock Text="{Binding InstructorName}" FontSize="13" Foreground="#64748B"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Border Grid.Column="3" Background="{Binding StatusBg}" CornerRadius="8" Padding="14,6" VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding Status}" FontSize="12" Foreground="{Binding StatusFg}" FontWeight="Bold"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="HoverBorder" Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="🔔  Thông báo môn học" Style="{StaticResource SectionHeader}" Margin="0" VerticalAlignment="Center"/>
                            <Button x:Name="BtnViewAllNotif" Content="Xem tất cả" Background="Transparent" BorderThickness="0"
                                    Foreground="#3B82F6" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Cursor="Hand" Click="BtnViewAllNotif_Click"/>
                        </Grid>

                        <Border Style="{StaticResource ModernCard}" Padding="8">
                            <ItemsControl x:Name="NotifItemsControl" Margin="0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Background="{Binding BackgroundBrush}" BorderThickness="0" Cursor="Hand" Margin="8,0,8,8" Click="BtnNotifItem_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="14">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding UnreadDotColor}" VerticalAlignment="Top" Margin="0,5,0,0"/>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="{Binding TitleWeight}" Foreground="{Binding TitleBrush}" TextWrapping="Wrap" Margin="0,0,0,4" LineHeight="20"/>
                                                    <TextBlock Text="{Binding Content}" FontSize="13" Foreground="#64748B" TextWrapping="Wrap" Margin="0,0,0,6" LineHeight="18" TextTrimming="CharacterEllipsis" MaxHeight="36"/>
                                                    <TextBlock Text="{Binding Time}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding TimeBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Grid x:Name="LoadingOverlay" Background="#AAFFFFFF" Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳ Đang tải dữ liệu..." FontSize="18" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Center"/>
                <TextBlock Text="Vui lòng đợi trong giây lát" FontSize="13" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>