<UserControl x:Class="e_learning_app.Views.StudentProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">

    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin"     Value="0,0,0,14"/>
        </Style>

        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding"      Value="10,4"/>
        </Style>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding"      Value="20,16"/>
            <Setter Property="Background"   Value="White"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.07" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Badge card -->
        <Style x:Key="BadgeCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding"      Value="14,12"/>
            <Setter Property="Background"   Value="White"/>
            <Setter Property="Width"        Value="120"/>
            <Setter Property="Margin"       Value="0,0,12,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.06" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Mini bar chart item -->
        <Style x:Key="BarChartItem" TargetType="StackPanel"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30,30,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== ROW 0: PROFILE HERO CARD ===== -->
            <Border Grid.Row="0" CornerRadius="24" Padding="32,28" Margin="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E40AF" Offset="0"/>
                        <GradientStop Color="#3B82F6" Offset="0.5"/>
                        <GradientStop Color="#8B5CF6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.2" Color="#3B82F6"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0" Width="90" Height="90" CornerRadius="22" Background="#FFFFFF33">
                        <Border Width="90" Height="90" CornerRadius="22">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#60A5FA" Offset="0"/>
                                    <GradientStop Color="#A78BFA" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="MA" FontSize="30" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Border>

                    <!-- Name + Level info -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Trần Minh Anh" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <Border Background="#FFFFFF22" CornerRadius="10" Padding="10,4" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="⭐ Scholar" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="MSSV: 22IT001234  ·  Lớp: CNTT2-K22" FontSize="13" Foreground="#BFDBFE" Margin="0,0,0,14"/>

                        <!-- Level + XP bar -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Border Background="#FFFFFF22" CornerRadius="12" Padding="12,6" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎖️ " FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Level 14" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <TextBlock Text="1,450 / 2,000 XP" FontSize="12" Foreground="#BFDBFE"/>
                                    <TextBlock Text="  → Level 15" FontSize="12" Foreground="#FCD34D" FontWeight="SemiBold"/>
                                </StackPanel>
                                <!-- XP Progress bar -->
                                <Border Width="240" Height="10" CornerRadius="5" Background="#FFFFFF33" HorizontalAlignment="Left">
                                    <Border HorizontalAlignment="Left" Width="174" Height="10" CornerRadius="5">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FCD34D" Offset="0"/>
                                                <GradientStop Color="#F59E0B" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Quick stats on right -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Border Background="#FFFFFF15" CornerRadius="16" Padding="18,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="🔥" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock Text="7 ngày" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="Streak học" FontSize="11" Foreground="#BFDBFE"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Height="1" Background="#FFFFFF22" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏆" FontSize="18" VerticalAlignment="Center"/>
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock Text="8 huy hiệu" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="Đã đạt được" FontSize="11" Foreground="#BFDBFE"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== ROW 2: QUICK STATS ===== -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📚" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="5" FontSize="26" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                        <TextBlock Text="Khóa đang học" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⏱️" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="42h" FontSize="26" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                        <TextBlock Text="Thời gian học" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="✅" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="34" FontSize="26" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                        <TextBlock Text="Bài hoàn thành" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource StatCard}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⭐" FontSize="24" HorizontalAlignment="Center"/>
                        <TextBlock Text="8.5" FontSize="26" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                        <TextBlock Text="Điểm trung bình" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== ROW 4: TROPHY CASE + STUDY CHART ===== -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Trophy Case (Bảng vàng) -->
                <StackPanel Grid.Column="0">
                    <Grid Margin="0,0,0,14">
                        <TextBlock Text="🏆  Bảng vàng thành tích" Style="{StaticResource SectionHeader}" Margin="0"/>
                        <TextBlock Text="8 huy hiệu đã đạt" FontSize="12" Foreground="#64748B"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Trophy showcase container -->
                    <Border Background="White" CornerRadius="20" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Featured / Top badge -->
                            <Border Background="#FFFBEB" CornerRadius="16" Padding="20,16" Margin="0,0,0,16">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FCD34D" Offset="0"/>
                                        <GradientStop Color="#F59E0B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.BorderThickness>2</Border.BorderThickness>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="60" Height="60" CornerRadius="16">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FCD34D" Offset="0"/>
                                                <GradientStop Color="#F59E0B" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="🌟" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Học sinh xuất sắc" FontSize="15" FontWeight="Bold" Foreground="#92400E"/>
                                            <Border Background="#FEF9C3" CornerRadius="6" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Huy hiệu vàng" FontSize="10" Foreground="#CA8A04" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Đạt điểm A+ trong cả học kỳ. Thành tích đặc biệt xuất sắc!" FontSize="12" Foreground="#78350F" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="Đạt được: 15/03/2026" FontSize="11" Foreground="#92400E" Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="✨" FontSize="24" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Badge grid -->
                            <WrapPanel>
                                <!-- Badge 1 - Earned -->
                                <Border Style="{StaticResource BadgeCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="52" Height="52" CornerRadius="14" Background="#EFF6FF" HorizontalAlignment="Center">
                                            <TextBlock Text="🔥" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Streak 7 ngày" FontSize="11" FontWeight="SemiBold" Foreground="#1E293B"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,2"/>
                                        <TextBlock Text="Đã đạt" FontSize="10" Foreground="#16A34A" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Badge 2 - Earned -->
                                <Border Style="{StaticResource BadgeCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="52" Height="52" CornerRadius="14" Background="#F0FDF4" HorizontalAlignment="Center">
                                            <TextBlock Text="💯" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Điểm tuyệt đối" FontSize="11" FontWeight="SemiBold" Foreground="#1E293B"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,2"/>
                                        <TextBlock Text="Đã đạt" FontSize="10" Foreground="#16A34A" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Badge 3 - Earned -->
                                <Border Style="{StaticResource BadgeCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="52" Height="52" CornerRadius="14" Background="#FFF7ED" HorizontalAlignment="Center">
                                            <TextBlock Text="⚡" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Học nhanh" FontSize="11" FontWeight="SemiBold" Foreground="#1E293B"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,2"/>
                                        <TextBlock Text="Đã đạt" FontSize="10" Foreground="#16A34A" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Badge 4 - Earned -->
                                <Border Style="{StaticResource BadgeCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="52" Height="52" CornerRadius="14" Background="#FFF1F2" HorizontalAlignment="Center">
                                            <TextBlock Text="❤️" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Chuyên cần" FontSize="11" FontWeight="SemiBold" Foreground="#1E293B"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,2"/>
                                        <TextBlock Text="Đã đạt" FontSize="10" Foreground="#16A34A" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Badge 5 - Locked -->
                                <Border Style="{StaticResource BadgeCard}" Background="#F8FAFC">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="52" Height="52" CornerRadius="14" Background="#F1F5F9" HorizontalAlignment="Center">
                                            <TextBlock Text="🔒" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#CBD5E1"/>
                                        </Border>
                                        <TextBlock Text="Bậc thầy Toán" FontSize="11" Foreground="#CBD5E1"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,2"/>
                                        <TextBlock Text="Chưa đạt" FontSize="10" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Badge 6 - Locked -->
                                <Border Style="{StaticResource BadgeCard}" Background="#F8FAFC">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="52" Height="52" CornerRadius="14" Background="#F1F5F9" HorizontalAlignment="Center">
                                            <TextBlock Text="🔒" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#CBD5E1"/>
                                        </Border>
                                        <TextBlock Text="Top 1 lớp" FontSize="11" Foreground="#CBD5E1"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,2"/>
                                        <TextBlock Text="Chưa đạt" FontSize="10" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT: Study Chart + Recent Activity -->
                <StackPanel Grid.Column="2">
                    <!-- Study time chart -->
                    <TextBlock Text="📊  Thời gian học 7 ngày qua" Style="{StaticResource SectionHeader}"/>
                    <Border Background="White" CornerRadius="20" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Bar chart -->
                            <Grid Height="120" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Mon -->
                                <Border Grid.Column="0" VerticalAlignment="Bottom" Height="58" CornerRadius="6,6,0,0" Background="#3B82F6" Opacity="0.5"/>
                                <!-- Tue -->
                                <Border Grid.Column="2" VerticalAlignment="Bottom" Height="80" CornerRadius="6,6,0,0" Background="#3B82F6" Opacity="0.6"/>
                                <!-- Wed -->
                                <Border Grid.Column="4" VerticalAlignment="Bottom" Height="38" CornerRadius="6,6,0,0" Background="#3B82F6" Opacity="0.4"/>
                                <!-- Thu -->
                                <Border Grid.Column="6" VerticalAlignment="Bottom" Height="100" CornerRadius="6,6,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <!-- Fri -->
                                <Border Grid.Column="8" VerticalAlignment="Bottom" Height="65" CornerRadius="6,6,0,0" Background="#3B82F6" Opacity="0.55"/>
                                <!-- Sat -->
                                <Border Grid.Column="10" VerticalAlignment="Bottom" Height="90" CornerRadius="6,6,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <!-- Sun -->
                                <Border Grid.Column="12" VerticalAlignment="Bottom" Height="55" CornerRadius="6,6,0,0" Background="#3B82F6" Opacity="0.5"/>
                            </Grid>

                            <!-- Day labels -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"  Text="T2" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2"  Text="T3" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4"  Text="T4" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="6"  Text="T5" FontSize="10" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="8"  Text="T6" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="10" Text="T7" FontSize="10" FontWeight="Bold" Foreground="#8B5CF6" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="12" Text="CN" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                            </Grid>

                            <Border Height="1" Background="#E2E8F0" Margin="0,12,0,12"/>

                            <!-- summary row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Tổng tuần này" FontSize="11" Foreground="#64748B"/>
                                    <TextBlock Text="6h 20m" FontSize="16" FontWeight="Bold" Foreground="#1E293B" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="Trung bình/ngày" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right"/>
                                    <TextBlock Text="54 phút" FontSize="16" FontWeight="Bold" Foreground="#3B82F6" Margin="0,2,0,0" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Recent Activity -->
                    <TextBlock Text="📋  Hoạt động gần đây" Style="{StaticResource SectionHeader}" Margin="0,20,0,14"/>
                    <Border Background="White" CornerRadius="18" Padding="18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                        </Border.Effect>
                        <StackPanel>
                            <!-- Activity item 1 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#EFF6FF">
                                    <TextBlock Text="🎬" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Xem bài 14 Toán cao cấp" FontSize="12" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock Text="Hôm nay, 14:30  ·  +150 XP" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="#F1F5F9" Margin="0,0,0,12"/>

                            <!-- Activity item 2 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#F0FDF4">
                                    <TextBlock Text="✅" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Hoàn thành Quiz Vật lý Lab 1" FontSize="12" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock Text="Hôm qua, 20:15  ·  +250 XP · 9/10 điểm" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="#F1F5F9" Margin="0,0,0,12"/>

                            <!-- Activity item 3 -->
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" Background="#FFF7ED">
                                    <TextBlock Text="🏆" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Nhận huy hiệu 'Streak 7 ngày'" FontSize="12" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock Text="02/04/2026  ·  +500 XP" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
