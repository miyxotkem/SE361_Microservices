<Window x:Class="e_learning_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:views="clr-namespace:e_learning_app.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        ResizeMode="CanResize"
        Title="EduFlow - Modern Learning Experience" Height="600" Width="1200"
        Background="#F0F2F5" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Window.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="TextDark" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>

        <!-- Sidebar Navigation Button Style -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="12" Margin="10,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0EAFF"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <Grid Margin="10,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,40">
                    <Border Width="40" Height="40" Background="{StaticResource PrimaryBlue}" CornerRadius="10">
                        <TextBlock Text="E" Foreground="White" FontWeight="Bold" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="EduSmart" VerticalAlignment="Center" Margin="12,0" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="btnDashBoard" Content="🏠   Bảng diều khiển" Style="{StaticResource NavButtonStyle}" Click="NavDashboard_Click"/>
                    <Button Content="🎓   Lớp học của tôi" Style="{StaticResource NavButtonStyle}" Click="NavClasses_Click"/>
                    <Button Content="📅   Lịch giảng dạy" Style="{StaticResource NavButtonStyle}" Click="NavSchedule_Click"/>
                    <Button Content="📋   Quản lý bài thi" Style="{StaticResource NavButtonStyle}" Click="NavExams_Click"/>
                    <Button Content="🔔   Thông báo lớp" Style="{StaticResource NavButtonStyle}" Click="NavNotifications_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="10,0,10,10">
                    <Button Click="OpenProfile_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ProfileBorder" Background="#F8FAFC" CornerRadius="15" Padding="10">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="35" Height="35" CornerRadius="10" Background="#3B82F6">
                                            <Grid>
                                                <TextBlock Text="★" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                                                <Border CornerRadius="10">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding ProfileImageUrl, TargetNullValue={x:Null}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <StackPanel Margin="10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName, FallbackValue='Tài khoản của tôi'}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextDark}"/>
                                            <TextBlock Text="Xem hồ sơ cá nhân" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ProfileBorder" Property="Background" Value="#F1F5F9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="🚪   Đăng xuất" Style="{StaticResource NavButtonStyle}" Click="BtnLogout_Click" Foreground="#EF4444" Margin="0,0,0,5"/>

                </StackPanel>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1" x:Name="MainContentArea" />
    </Grid>
</Window>