<Window x:Class="e_learning_app.StudentMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:e_learning_app.Views"
        ResizeMode="CanResize"
        Title="Student Panel" Height="600" Width="1280"
        Background="#F0F2F5" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlue"   Color="#3B82F6"/>
        <SolidColorBrush x:Key="TextDark"      Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#64748B"/>
        <SolidColorBrush x:Key="CardBg"        Color="#FFFFFF"/>

        <!-- Student Nav Button – same radius/style language as teacher -->
        <Style x:Key="StudentNavBtn" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Foreground"              Value="{StaticResource TextMuted}"/>
            <Setter Property="Height"                  Value="50"/>
            <Setter Property="Margin"                  Value="0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="12" Margin="10,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0EAFF"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active nav item -->
        <Style x:Key="StudentNavBtnActive" TargetType="Button" BasedOn="{StaticResource StudentNavBtn}">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Logout button -->
        <Style x:Key="LogoutBtn" TargetType="Button" BasedOn="{StaticResource StudentNavBtn}">
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <Grid Margin="10,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,40">
                    <Border Width="40" Height="40" CornerRadius="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="E" Foreground="White" FontWeight="Bold" FontSize="22"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="EduSmart" VerticalAlignment="Center" Margin="12,0,0,0"
                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                </StackPanel>

                <!-- Nav items -->
                <StackPanel Grid.Row="1">
                    <!-- Section label -->
                    <Button x:Name="BtnDashboard" Content="🏠   Bảng diều khiển"
                            Style="{StaticResource StudentNavBtnActive}" Click="BtnDashboard_Click"/>
                    <Button x:Name="BtnCourses"  Content="📚   Khóa học của tôi"
                            Style="{StaticResource StudentNavBtn}" Click="BtnCourses_Click"/>
                    <Button x:Name="BtnSchedule" Content="📅   Thời khóa biểu"
                            Style="{StaticResource StudentNavBtn}" Click="BtnSchedule_Click"/>
                    <Button x:Name="BtnQuiz"     Content="📝   Bài kiểm tra"
                            Style="{StaticResource StudentNavBtn}" Click="BtnQuiz_Click"/>
                    <Button x:Name="BtnNotifications" Content="🔔   Thông báo"
                            Style="{StaticResource StudentNavBtn}" Click="BtnNotifications_Click"/>
                </StackPanel>

                <!-- User info (Clickable) -->
                <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="10,0,10,10">
                    <Button Click="OpenProfile_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ProfileBorder" Background="#F8FAFC" CornerRadius="15" Padding="10">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="35" Height="35" CornerRadius="10" Background="#3B82F6">
                                            <Grid>
                                                <TextBlock Text="★" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold" FontSize="18"/>
                                                <Border CornerRadius="10">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding ProfileImageUrl, TargetNullValue={x:Null}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <StackPanel Margin="10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName, FallbackValue='Tài khoản của tôi'}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextDark}"/>
                                            <TextBlock Text="Xem hồ sơ cá nhân" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ProfileBorder" Property="Background" Value="#F1F5F9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="🚪   Đăng xuất" Style="{StaticResource NavButtonStyle}" Click="BtnLogout_Click" Foreground="#EF4444" Margin="0"/>
                </StackPanel>
            </Grid>
            
        </Border>

        <!-- ===== MAIN CONTENT AREA ===== -->
        <ContentControl Grid.Column="1" x:Name="StudentContentArea" />
    </Grid>
</Window>
