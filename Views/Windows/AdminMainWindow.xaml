<Window x:Class="e_learning_app.AdminMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:e_learning_app.Views"
        ResizeMode="CanResize"
        Title="EduFlow – Admin Panel" Height="650" Width="1280" MinHeight="480" MinWidth="900"
        Background="#F0F2F5" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Window.Resources>
        <SolidColorBrush x:Key="AdminAccent"  Color="#7C3AED"/>
        <SolidColorBrush x:Key="AdminLight"   Color="#EDE9FE"/>
        <SolidColorBrush x:Key="TextDark"     Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#64748B"/>

        <!-- Admin Nav Button -->
        <Style x:Key="AdminNavBtn" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Foreground"              Value="{StaticResource TextMuted}"/>
            <Setter Property="Height"                  Value="50"/>
            <Setter Property="Margin"                  Value="0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="12" Margin="10,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F5F3FF"/>
                                <Setter Property="Foreground" Value="{StaticResource AdminAccent}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EDE9FE"/>
                                <Setter Property="Foreground" Value="{StaticResource AdminAccent}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active nav item -->
        <Style x:Key="AdminNavBtnActive" TargetType="Button" BasedOn="{StaticResource AdminNavBtn}">
            <Setter Property="Background" Value="#EDE9FE"/>
            <Setter Property="Foreground" Value="{StaticResource AdminAccent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <Grid Margin="10,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,10">
                    <Border Width="40" Height="40" CornerRadius="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C3AED" Offset="0"/>
                                <GradientStop Color="#4F46E5" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="A" Foreground="White" FontWeight="Bold" FontSize="22"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="EduSmart" Margin="12,0,0,0" VerticalAlignment="Center"
                               FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                </StackPanel>

                <!-- Admin badge -->
                <Border Grid.Row="0" HorizontalAlignment="Left" Margin="20,52,0,10"
                        Background="#F5F3FF" CornerRadius="8" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛡️" FontSize="11"/>
                        <TextBlock Text="  Quản trị hệ thống" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AdminAccent}"/>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,10,0,0">
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="TỔNG QUAN" FontSize="10" FontWeight="Bold" Foreground="#CBD5E1"
                                   Margin="25,0,0,8"/>
                        <Button x:Name="BtnDashboard" Content="🏠   Bảng diều khiển"
                                Style="{StaticResource AdminNavBtnActive}" Click="BtnDashboard_Click"/>

                        <TextBlock Text="TÀI KHOẢN" FontSize="10" FontWeight="Bold" Foreground="#CBD5E1"
                                   Margin="25,14,0,8"/>
                        <Button x:Name="BtnUsers" Content="👥   Quản lý người dùng"
                                Style="{StaticResource AdminNavBtn}" Click="BtnUsers_Click"/>

                        <TextBlock Text="HỆ THỐNG" FontSize="10" FontWeight="Bold" Foreground="#CBD5E1"
                                   Margin="25,14,0,8"/>
                        <Button x:Name="BtnSettings" Content="⚙️   Cài đặt hệ thống"
                                Style="{StaticResource AdminNavBtn}" Click="BtnSettings_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom: Admin info + Logout -->
                <StackPanel Grid.Row="2">
                    <Border Background="#F8FAFC" CornerRadius="15" Padding="10" Margin="10,0,10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="38" Height="38" CornerRadius="10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C3AED" Offset="0"/>
                                        <GradientStop Color="#4F46E5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock x:Name="TxtAdminInitials" Text="AD" Foreground="White"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           FontWeight="Bold" FontSize="13"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtAdminName" Text="Administrator"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="{StaticResource TextDark}"/>
                                <TextBlock Text="🛡️ Super Admin" FontSize="10"
                                           Foreground="{StaticResource AdminAccent}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Button Content="🚪   Đăng xuất" Style="{StaticResource LogoutBtn}"
                            Click="BtnLogout_Click" Margin="0,0,0,4"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT AREA ===== -->
        <ContentControl Grid.Column="1" x:Name="AdminContentArea"/>
    </Grid>
</Window>
