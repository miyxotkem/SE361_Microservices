<Window x:Class="e_learning_app.StudentMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:e_learning_app.Views"
        ResizeMode="CanResize"
        Title="EduSmart – Student Portal" Height="600" Width="1280"
        Background="#F0F2F5" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlue"   Color="#3B82F6"/>
        <SolidColorBrush x:Key="TextDark"      Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#64748B"/>
        <SolidColorBrush x:Key="CardBg"        Color="#FFFFFF"/>

        <!-- Student Nav Button – same radius/style language as teacher -->
        <Style x:Key="StudentNavBtn" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="Foreground"              Value="{StaticResource TextMuted}"/>
            <Setter Property="Height"                  Value="50"/>
            <Setter Property="Margin"                  Value="0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="12" Margin="10,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0EAFF"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active nav item -->
        <Style x:Key="StudentNavBtnActive" TargetType="Button" BasedOn="{StaticResource StudentNavBtn}">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
            <Grid Margin="10,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,40">
                    <Border Width="40" Height="40" CornerRadius="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="E" Foreground="White" FontWeight="Bold" FontSize="22"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="EduSmart" VerticalAlignment="Center" Margin="12,0,0,0"
                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                </StackPanel>

                <!-- Nav items -->
                <StackPanel Grid.Row="1">
                    <!-- Section label -->
                    <TextBlock Text="TỔNG QUAN" FontSize="10" FontWeight="Bold" Foreground="#CBD5E1"
                               Margin="25,0,0,8" />
                    <Button x:Name="BtnDashboard" Content="🏠   Trang chủ"
                            Style="{StaticResource StudentNavBtnActive}" Click="BtnDashboard_Click"/>

                    <TextBlock Text="HỌC TẬP" FontSize="10" FontWeight="Bold" Foreground="#CBD5E1"
                               Margin="25,14,0,8"/>
                    <Button x:Name="BtnCourses"  Content="📚   Khóa học của tôi"
                            Style="{StaticResource StudentNavBtn}" Click="BtnCourses_Click"/>
                    <Button x:Name="BtnQuiz"     Content="📝   Bài kiểm tra"
                            Style="{StaticResource StudentNavBtn}" Click="BtnQuiz_Click"/>

                    <TextBlock Text="CÁ NHÂN" FontSize="10" FontWeight="Bold" Foreground="#CBD5E1"
                               Margin="25,14,0,8"/>
                    <Button x:Name="BtnProfile"  Content="🏆   Hồ sơ &amp; Thành tích"
                            Style="{StaticResource StudentNavBtn}" Click="BtnProfile_Click"/>
                    <Button x:Name="BtnNotifications" Content="🔔   Thông báo"
                            Style="{StaticResource StudentNavBtn}" Click="BtnNotifications_Click"/>
                </StackPanel>

                <!-- User info -->
                <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="15" Padding="10" Margin="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="38" Height="38" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#60A5FA" Offset="0"/>
                                    <GradientStop Color="#A78BFA" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="MA" Foreground="White" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Trần Minh Anh" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextDark}"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎖️ Level 14" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text=" · Học sinh" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="2" Background="#EFF6FF" CornerRadius="8" Padding="6,4" Cursor="Hand">
                            <TextBlock Text="↗" FontSize="12" Foreground="#3B82F6" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT AREA ===== -->
        <ContentControl Grid.Column="1" x:Name="StudentContentArea">
            <views:StudentDashboardView/>
        </ContentControl>
    </Grid>
</Window>
