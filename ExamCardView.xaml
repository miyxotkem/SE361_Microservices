<UserControl x:Class="e_learning_app.ExamCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:e_learning_app"
             mc:Ignorable="d" 
             d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Style for action buttons -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Style for Status Text -->
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#16A34A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="📝 Nháp"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPublished}" Value="True">
                    <Setter Property="Text" Value="🔒 Đã Khóa"/>
                    <Setter Property="Foreground" Value="#DC2626"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Text" Value="Đang Mở"/>
                    <Setter Property="Foreground" Value="#16A34A"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Style for Status Icon -->
        <Style x:Key="StatusIconStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#16A34A"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Text" Value="📝"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPublished}" Value="True">
                    <Setter Property="Text" Value="🔒"/>
                    <Setter Property="Foreground" Value="#DC2626"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Text" Value="☑"/>
                    <Setter Property="Foreground" Value="#16A34A"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Style for Status Border Background -->
        <Style x:Key="StatusBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FEF3C7"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPublished}" Value="True">
                    <Setter Property="Background" Value="#FEE2E2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#DCFCE7"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="White" 
            BorderBrush="#E2E8F0" 
            BorderThickness="1" 
            CornerRadius="16" 
            Padding="24"
            Margin="0,0,0,16">
        <!-- Subtle shadow -->
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Color="Black"/>
        </Border.Effect>
        
        <StackPanel>
            <!-- ================= TOP BADGES ================= -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <!-- Quiz Badge -->
                <Border Background="#EFF6FF" CornerRadius="14" Padding="12,6" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎯" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Type, FallbackValue=Quiz}" Foreground="#2563EB" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <!-- Status Badge (Đang Mở) -->
                <Border Style="{StaticResource StatusBorderStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource StatusIconStyle}"/>
                        <TextBlock Style="{StaticResource StatusTextStyle}"/>
                    </StackPanel>
                </Border>
                
                <!-- Duration Badge (30 phút) -->
                <Border Background="#F8FAFC" CornerRadius="14" Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏱" Foreground="#475569" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TimeLimitMinutes, StringFormat='\{0\} phút', FallbackValue='30 phút'}" Foreground="#475569" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- ================= MIDDLE ROW (Title & Actions) ================= -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Title & ClassName -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title, FallbackValue='Quiz Chương 1: Giới Thiệu Lập Trình'}" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="#1E293B" 
                               TextWrapping="Wrap"
                               Margin="0,0,0,4"/>
                    
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏫" Foreground="#64748B" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ClassName, FallbackValue='SE104.O21 - Công nghệ phần mềm'}" 
                                   FontSize="13" 
                                   Foreground="#64748B" 
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnView" Style="{StaticResource ActionButtonStyle}" Tag="{Binding Id}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👁" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Xem" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnEdit" Style="{StaticResource ActionButtonStyle}" Tag="{Binding Id}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✎" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sửa" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnDelete" Style="{StaticResource ActionButtonStyle}" Tag="{Binding Id}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Xóa" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
            
            <!-- ================= SUBTITLE ================= -->
            <TextBlock Text="{Binding Description, FallbackValue='Kiểm tra kiến thức cơ bản về C# và OOP'}" 
                       Foreground="#64748B" 
                       FontSize="14" 
                       Margin="0,0,0,16"
                       TextWrapping="Wrap"/>
            
            <!-- ================= BOTTOM DETAILS ================= -->
            <StackPanel Orientation="Horizontal">
                <!-- Question Count -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📊" Foreground="#94A3B8" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalQuestions, StringFormat='\{0\} câu', FallbackValue='10 câu'}" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Text=" • " Foreground="#CBD5E1" FontSize="14" Margin="8,0" VerticalAlignment="Center"/>
                
                <!-- Pass Score -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎯" Foreground="#94A3B8" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PassingScore, StringFormat='Điểm qua: \{0\}%', FallbackValue='Điểm qua: 50%'}" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Text=" • " Foreground="#CBD5E1" FontSize="14" Margin="8,0" VerticalAlignment="Center"/>
                
                <!-- Date -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📅" Foreground="#94A3B8" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CreatedAt, StringFormat='\{0:dd/MM/yyyy\}', FallbackValue='12/04/2026'}" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
            
        </StackPanel>
    </Border>
</UserControl>
