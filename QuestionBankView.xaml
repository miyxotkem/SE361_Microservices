<UserControl x:Class="e_learning_app.Views.QuestionBankView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding"      Value="10,4"/>
        </Style>
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,30,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="📝  Ngân hàng câu hỏi" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Quản lý và tổ chức toàn bộ câu hỏi theo môn học và mức độ." FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnImport" Content="📥  Import"
                        Background="#F1F5F9" Foreground="#475569"
                        Style="{StaticResource RoundBtn}" Padding="16,9" FontSize="13" Margin="0,0,10,0"
                        Click="BtnImport_Click"/>
                <Button x:Name="BtnAddQuestion" Content="+ Thêm câu hỏi"
                        Background="#3B82F6" Foreground="White"
                        Style="{StaticResource RoundBtn}" Padding="16,9" FontSize="13" FontWeight="SemiBold"
                        Click="BtnAddQuestion_Click"/>
            </StackPanel>
        </Grid>

        <!-- STAT CARDS -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="White" CornerRadius="14" Padding="18,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="10" Background="#EFF6FF">
                        <TextBlock Text="📚" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0">
                        <TextBlock x:Name="TxtTotalCount" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Tổng câu hỏi" FontSize="11" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="White" CornerRadius="14" Padding="18,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="10" Background="#FEE2E2">
                        <TextBlock Text="🔴" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0">
                        <TextBlock x:Name="TxtHardCount" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Mức khó" FontSize="11" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="White" CornerRadius="14" Padding="18,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="10" Background="#FEF3C7">
                        <TextBlock Text="🟡" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0">
                        <TextBlock x:Name="TxtMidCount" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Mức trung bình" FontSize="11" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="6" Background="White" CornerRadius="14" Padding="18,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="10" Background="#DCFCE7">
                        <TextBlock Text="🟢" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0">
                        <TextBlock x:Name="TxtEasyCount" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Mức dễ" FontSize="11" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- MAIN -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- FILTER PANEL -->
            <Border Grid.Column="0" Background="White" CornerRadius="18" Padding="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Lọc câu hỏi" FontWeight="Bold" FontSize="14" Foreground="#1E293B" Margin="0,0,0,16"/>

                    <TextBlock Text="MÔN HỌC" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <RadioButton Content="Tất cả" IsChecked="True" Margin="0,0,0,6" FontSize="13" Foreground="#1E293B" Tag="Tất cả"
                                 Checked="SubjectRadio_Changed"/>
                    <RadioButton Content="Toán học"  Margin="0,0,0,6" FontSize="13" Foreground="#475569" Tag="Toán học"
                                 Checked="SubjectRadio_Changed"/>
                    <RadioButton Content="Vật lý"    Margin="0,0,0,6" FontSize="13" Foreground="#475569" Tag="Vật lý"
                                 Checked="SubjectRadio_Changed"/>
                    <RadioButton Content="Hóa học"   Margin="0,0,0,6" FontSize="13" Foreground="#475569" Tag="Hóa học"
                                 Checked="SubjectRadio_Changed"/>
                    <RadioButton Content="Sinh học"  Margin="0,0,0,6" FontSize="13" Foreground="#475569" Tag="Sinh học"
                                 Checked="SubjectRadio_Changed"/>
                    <RadioButton Content="Ngữ văn"   Margin="0,0,0,16" FontSize="13" Foreground="#475569" Tag="Ngữ văn"
                                 Checked="SubjectRadio_Changed"/>

                    <TextBlock Text="MỨC ĐỘ" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <CheckBox Content="Dễ"         IsChecked="True" Margin="0,0,0,6" FontSize="13" Tag="Dễ"
                              Checked="LevelCheck_Changed" Unchecked="LevelCheck_Changed"/>
                    <CheckBox Content="Trung bình" IsChecked="True" Margin="0,0,0,6" FontSize="13" Tag="Trung bình"
                              Checked="LevelCheck_Changed" Unchecked="LevelCheck_Changed"/>
                    <CheckBox Content="Khó"        IsChecked="True" Margin="0,0,0,16" FontSize="13" Tag="Khó"
                              Checked="LevelCheck_Changed" Unchecked="LevelCheck_Changed"/>

                    <TextBlock Text="LOẠI CÂU HỎI" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <CheckBox Content="Trắc nghiệm"        IsChecked="True" Margin="0,0,0,6" FontSize="13" Tag="Trắc nghiệm"
                              Checked="TypeCheck_Changed" Unchecked="TypeCheck_Changed"/>
                    <CheckBox Content="Tự luận"            IsChecked="True" Margin="0,0,0,6" FontSize="13" Tag="Tự luận"
                              Checked="TypeCheck_Changed" Unchecked="TypeCheck_Changed"/>
                    <CheckBox Content="Điền vào chỗ trống" IsChecked="True" Margin="0,0,0,6" FontSize="13" Tag="Điền vào chỗ trống"
                              Checked="TypeCheck_Changed" Unchecked="TypeCheck_Changed"/>

                    <Button x:Name="BtnApplyFilter" Content="Áp dụng bộ lọc"
                            Background="#3B82F6" Foreground="White"
                            Style="{StaticResource RoundBtn}" Padding="0,10" Margin="0,16,0,0"
                            FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Stretch"
                            Click="BtnApplyFilter_Click"/>
                </StackPanel>
            </Border>

            <!-- QUESTION LIST -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="14"/>
                        <TextBox x:Name="TxtSearch" Grid.Column="1"
                                 Background="Transparent" BorderThickness="0" Height="42"
                                 Padding="10,0" VerticalContentAlignment="Center" FontSize="13"
                                 Foreground="#1E293B"
                                 TextChanged="TxtSearch_TextChanged"/>
                        <TextBlock x:Name="TxtSearchPH" Grid.Column="1"
                                   Text="Tìm kiếm câu hỏi..." Foreground="#94A3B8" FontSize="13"
                                   Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        <Border Grid.Column="2" Margin="0,6,8,6" Background="#F1F5F9" CornerRadius="8" Padding="12,6">
                            <TextBlock x:Name="TxtResultCount" FontSize="12" Foreground="#64748B"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Dynamic question list -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="QuestionsPanel"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
