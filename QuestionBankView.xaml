<UserControl x:Class="e_learning_app.Views.QuestionBankView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="TextDark"    Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#64748B"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#3B82F6"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="18,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#64748B"/>
            <Setter Property="BorderBrush"     Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuestionRow" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding"      Value="20,14"/>
            <Setter Property="Margin"       Value="0,0,0,8"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.04" Color="Black"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFCFF"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.08" Color="#3B82F6"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiffBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="10,4"/>
        </Style>

        <Style x:Key="TypeBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="10,4"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="32,20"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Ngân hàng câu hỏi" FontSize="22"
                               FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Quản lý toàn bộ câu hỏi theo môn và chương"
                               FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📥 Nhập file" Style="{StaticResource GhostBtn}"
                            Margin="0,0,10,0" Width="120"/>
                    <Button Content="+ Thêm câu hỏi" Style="{StaticResource PrimaryBtn}"
                            Width="150"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Filter Panel -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="0,0,1,0" Padding="20,24">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Bộ lọc" FontSize="14" FontWeight="Bold"
                                   Foreground="#1E293B" Margin="0,0,0,16"/>

                        <!-- Môn học -->
                        <TextBlock Text="MÔN HỌC" FontSize="10" FontWeight="Bold"
                                   Foreground="#94A3B8" Margin="0,0,0,10" />
                        <StackPanel>
                            <Border CornerRadius="10" Padding="12,8" Margin="0,2"
                                    Background="#EFF6FF" Cursor="Hand">
                                <Grid>
                                    <TextBlock Text="Tất cả môn" FontSize="13"
                                               Foreground="#3B82F6" FontWeight="SemiBold"/>
                                    <Border Background="#3B82F6" CornerRadius="8" Padding="8,2"
                                            HorizontalAlignment="Right">
                                        <TextBlock Text="148" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border CornerRadius="10" Padding="12,8" Margin="0,2" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <TextBlock Text="💻 Lập trình Web" FontSize="13" Foreground="#1E293B"/>
                                    <TextBlock Text="42" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border CornerRadius="10" Padding="12,8" Margin="0,2" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <TextBlock Text="🗃️ Cơ sở dữ liệu" FontSize="13" Foreground="#1E293B"/>
                                    <TextBlock Text="35" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border CornerRadius="10" Padding="12,8" Margin="0,2" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <TextBlock Text="🤖 Trí tuệ nhân tạo" FontSize="13" Foreground="#1E293B"/>
                                    <TextBlock Text="28" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border CornerRadius="10" Padding="12,8" Margin="0,2" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F8FAFC"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <TextBlock Text="🔢 Giải tích" FontSize="13" Foreground="#1E293B"/>
                                    <TextBlock Text="43" FontSize="11" Foreground="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Separator Margin="0,16" Background="#F1F5F9"/>

                        <!-- Loại câu hỏi -->
                        <TextBlock Text="LOẠI CÂU HỎI" FontSize="10" FontWeight="Bold"
                                   Foreground="#94A3B8" Margin="0,0,0,10"/>
                        <StackPanel>
                            <CheckBox Content="Trắc nghiệm" FontSize="13" Foreground="#1E293B"
                                      IsChecked="True" Margin="0,6"/>
                            <CheckBox Content="Tự luận" FontSize="13" Foreground="#1E293B" Margin="0,6"/>
                            <CheckBox Content="Điền vào chỗ trống" FontSize="13" Foreground="#1E293B" Margin="0,6"/>
                            <CheckBox Content="Ghép đôi" FontSize="13" Foreground="#1E293B" Margin="0,6"/>
                        </StackPanel>

                        <Separator Margin="0,16" Background="#F1F5F9"/>

                        <!-- Độ khó -->
                        <TextBlock Text="ĐỘ KHÓ" FontSize="10" FontWeight="Bold"
                                   Foreground="#94A3B8" Margin="0,0,0,10"/>
                        <StackPanel>
                            <CheckBox Content="Dễ" FontSize="13" Foreground="#1E293B"
                                      IsChecked="True" Margin="0,6"/>
                            <CheckBox Content="Trung bình" FontSize="13" Foreground="#1E293B"
                                      IsChecked="True" Margin="0,6"/>
                            <CheckBox Content="Khó" FontSize="13" Foreground="#1E293B" Margin="0,6"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Background="White" Padding="24,14"
                        BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Search -->
                        <Border Grid.Column="0" Background="#F8FAFC" CornerRadius="12"
                                Padding="12,0" Height="40" Width="320"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🔍" FontSize="14" Margin="0,0,8,0"/>
                                <TextBox Background="Transparent" BorderThickness="0"
                                         FontSize="13" Foreground="#94A3B8"
                                         Text="Tìm kiếm câu hỏi..."
                                         VerticalContentAlignment="Center" Width="250"/>
                            </StackPanel>
                        </Border>
                        <!-- Summary -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="148 câu hỏi" FontSize="13"
                                       Foreground="#64748B" VerticalAlignment="Center"
                                       Margin="0,0,16,0"/>
                            <Button Content="Tạo đề thi" Style="{StaticResource PrimaryBtn}"
                                    Width="120"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Question List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Padding="24,20">
                    <StackPanel>

                        <!-- Question 1 -->
                        <Border Style="{StaticResource QuestionRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Style="{StaticResource TypeBadge}" Background="#EFF6FF" Margin="0,0,8,0">
                                            <TextBlock Text="Trắc nghiệm" FontSize="11" Foreground="#3B82F6" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Style="{StaticResource DiffBadge}" Background="#F0FDF4">
                                            <TextBlock Text="Dễ" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Text="💻 Lập trình Web  •  Chương 2" FontSize="11"
                                                   Foreground="#94A3B8" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="HTML là viết tắt của từ nào sau đây?"
                                               FontSize="14" Foreground="#1E293B" FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="A. HyperText Markup Language   B. High Tech Modern Language   C. Home Tool Markup Language   D. Hyper Transfer Markup Language"
                                               FontSize="12" Foreground="#64748B" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="✏️" FontSize="16" Cursor="Hand" Margin="8,0"/>
                                    <TextBlock Text="🗑️" FontSize="16" Cursor="Hand" Margin="8,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Question 2 -->
                        <Border Style="{StaticResource QuestionRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Style="{StaticResource TypeBadge}" Background="#FDF4FF" Margin="0,0,8,0">
                                            <TextBlock Text="Tự luận" FontSize="11" Foreground="#9333EA" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Style="{StaticResource DiffBadge}" Background="#FFF7ED">
                                            <TextBlock Text="Trung bình" FontSize="11" Foreground="#F59E0B" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Text="🗃️ Cơ sở dữ liệu  •  Chương 4" FontSize="11"
                                                   Foreground="#94A3B8" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="Trình bày sự khác biệt giữa mô hình quan hệ và mô hình hướng đối tượng trong cơ sở dữ liệu."
                                               FontSize="14" Foreground="#1E293B" FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="Phân tích ít nhất 3 tiêu chí: cấu trúc dữ liệu, tính kế thừa, hiệu năng truy vấn."
                                               FontSize="12" Foreground="#64748B" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="✏️" FontSize="16" Cursor="Hand" Margin="8,0"/>
                                    <TextBlock Text="🗑️" FontSize="16" Cursor="Hand" Margin="8,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Question 3 -->
                        <Border Style="{StaticResource QuestionRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Style="{StaticResource TypeBadge}" Background="#EFF6FF" Margin="0,0,8,0">
                                            <TextBlock Text="Trắc nghiệm" FontSize="11" Foreground="#3B82F6" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Style="{StaticResource DiffBadge}" Background="#FEF2F2">
                                            <TextBlock Text="Khó" FontSize="11" Foreground="#DC2626" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Text="🤖 Trí tuệ nhân tạo  •  Chương 6" FontSize="11"
                                                   Foreground="#94A3B8" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="Trong thuật toán Gradient Descent, learning rate ảnh hưởng thế nào đến quá trình hội tụ?"
                                               FontSize="14" Foreground="#1E293B" FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="A. Không ảnh hưởng   B. Learning rate lớn → hội tụ nhanh hơn   C. Learning rate nhỏ → hội tụ chậm nhưng ổn định hơn   D. B và C đều đúng"
                                               FontSize="12" Foreground="#64748B" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="✏️" FontSize="16" Cursor="Hand" Margin="8,0"/>
                                    <TextBlock Text="🗑️" FontSize="16" Cursor="Hand" Margin="8,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Question 4 -->
                        <Border Style="{StaticResource QuestionRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Style="{StaticResource TypeBadge}" Background="#F0FDF4" Margin="0,0,8,0">
                                            <TextBlock Text="Điền vào chỗ trống" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Style="{StaticResource DiffBadge}" Background="#F0FDF4">
                                            <TextBlock Text="Dễ" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Text="🔢 Giải tích  •  Chương 1" FontSize="11"
                                                   Foreground="#94A3B8" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="Giới hạn của hàm f(x) = (x² - 1)/(x - 1) khi x tiến đến 1 là ___."
                                               FontSize="14" Foreground="#1E293B" FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="Đáp án: 2" FontSize="12" Foreground="#16A34A"
                                               FontWeight="SemiBold" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="✏️" FontSize="16" Cursor="Hand" Margin="8,0"/>
                                    <TextBlock Text="🗑️" FontSize="16" Cursor="Hand" Margin="8,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
