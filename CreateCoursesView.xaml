<UserControl x:Class="e_learning_app.CreateCoursesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="FieldLabelStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="6" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10"/>
                            <TextBlock Text="{TemplateBinding Tag}" Margin="12,0,30,0" VerticalAlignment="Center" Foreground="#94A3B8" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ContentPresenter Margin="12,0,30,0" VerticalAlignment="Center" Content="{TemplateBinding SelectionBoxItem}" IsHitTestVisible="False"/>
                            <Path x:Name="Arrow" Data="M0,0 L4,4 L8,0 Z" Fill="#64748B" HorizontalAlignment="Right" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <ToggleButton Background="Transparent" BorderThickness="0" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200" Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorRadioStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}" x:Name="BgEllipse"/>
                            <Path x:Name="CheckIcon" Data="M10,18 L15,23 L26,12" Stroke="White" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid Margin="40,80,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Top">
                <TextBlock Text="Xem trước hiển thị" FontSize="20" FontWeight="Bold" Margin="0,0,0,25" Foreground="#1E293B"/>
                <Border Width="320" CornerRadius="20" Background="White" HorizontalAlignment="Left">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border x:Name="PreviewHeader" Height="100" CornerRadius="20,20,0,0" Background="#3B82F6">
                            <TextBlock x:Name="PreviewEmoji" Text="📚" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Padding="25">
                            <StackPanel>
                                <TextBlock x:Name="PreviewTitle" Text="Tên môn học" FontSize="18" FontWeight="Bold" Foreground="#1E293B" TextWrapping="Wrap"/>
                                <TextBlock x:Name="PreviewClass" Text="Lớp • Học kỳ" Foreground="#64748B" FontSize="13" Margin="0,5,0,15" TextWrapping="Wrap"/>
                                <TextBlock x:Name="PreviewDesc" Text="Mô tả tóm tắt môn học sẽ hiển thị ở đây..." Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Height="40" TextTrimming="CharacterEllipsis"/>
                                <Separator Background="#F1F5F9" Margin="0,15,0,15"/>
                                <UniformGrid Columns="2">
                                    <Border Height="38" Background="#3B82F6" CornerRadius="10" Margin="4,0">
                                        <TextBlock Text="Vào lớp" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Height="38" Background="#F1F5F9" CornerRadius="10" Margin="4,0">
                                        <TextBlock Text="Chi tiết" Foreground="#475569" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Background="White" CornerRadius="20" Margin="20,0,0,0" Padding="0,20,10,20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="35,0,30,0">
                    <StackPanel>
                        <TextBlock Text="Thiết lập lớp học" FontSize="24" FontWeight="Bold" Margin="0,0,0,30" Foreground="#1E293B"/>

                        <TextBlock Text="Tên môn học" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="TxtTitle" Style="{StaticResource ModernTextBox}" Height="42" Margin="0,0,0,18" TextChanged="Sync_UI"/>

                        <TextBlock Text="Mô tả chi tiết" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="TxtDescription" Style="{StaticResource ModernTextBox}" Height="100" Margin="0,0,0,18" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="12,10" TextChanged="Sync_UI"/>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Mã lớp học" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TxtClass" Style="{StaticResource ModernTextBox}" Height="42" TextChanged="Sync_UI"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Loại môn học" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="CbCourseType" Style="{StaticResource ModernComboBox}" Tag="Chọn loại môn" SelectedIndex="0">
                                    <ComboBoxItem Content="Đại cương"/>
                                    <ComboBoxItem Content="Cơ sở ngành"/>
                                    <ComboBoxItem Content="Chuyên ngành"/>
                                    <ComboBoxItem Content="Đồ án"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Khoa" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="TxtCategory" Style="{StaticResource ModernTextBox}" Height="42" Margin="0,0,0,18" TextChanged="Sync_UI"/>

                        <!-- LỊCH HỌC -->
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Ngày học"/>
                                <ComboBox SelectedIndex="0" SelectionChanged="CbDayOfWeek_SelectionChanged" Style="{StaticResource ModernComboBox}" x:Name="CbDayOfWeek">
                                    <ComboBoxItem Content="Hình thức 2"/>
                                    <ComboBoxItem Content="Thứ 2"/>
                                    <ComboBoxItem Content="Thứ 3"/>
                                    <ComboBoxItem Content="Thứ 4"/>
                                    <ComboBoxItem Content="Thứ 5"/>
                                    <ComboBoxItem Content="Thứ 6"/>
                                    <ComboBoxItem Content="Thứ 7"/>
                                    <ComboBoxItem Content="Chủ nhật"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tiết bắt đầu"/>
                                <TextBox Height="42" Style="{StaticResource ModernTextBox}" Tag="Từ tiết" Text="0" TextChanged="Sync_UI" x:Name="TxtStartPeriod"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Tiết kết thúc"/>
                                <TextBox Height="42" Style="{StaticResource ModernTextBox}" Tag="Đến tiết" Text="0" TextChanged="Sync_UI" x:Name="TxtEndPeriod"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Học kỳ" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="CbSemester" Style="{StaticResource ModernComboBox}" Tag="Chọn học kỳ" SelectedIndex="0" SelectionChanged="Sync_UI_Selection">
                                    <ComboBoxItem Content="Học kỳ 1"/>
                                    <ComboBoxItem Content="Học kỳ 2"/>
                                    <ComboBoxItem Content="Học kỳ hè"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Năm học" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="CbYear" Style="{StaticResource ModernComboBox}" Tag="Chọn năm học" SelectionChanged="Sync_UI_Selection"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Biểu tượng (Emoji)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="TxtEmoji" Style="{StaticResource ModernTextBox}" Width="60" Height="42" HorizontalAlignment="Left" MaxLength="2" TextChanged="Sync_UI" Text="📚"/>

                        <TextBlock Text="Màu sắc chủ đề" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                            <RadioButton GroupName="ThemeColors" Background="#3B82F6" Style="{StaticResource ColorRadioStyle}" IsChecked="True" Checked="ColorRadio_Checked"/>
                            <RadioButton GroupName="ThemeColors" Background="#8B5CF6" Style="{StaticResource ColorRadioStyle}" Checked="ColorRadio_Checked"/>
                            <RadioButton GroupName="ThemeColors" Background="#F59E0B" Style="{StaticResource ColorRadioStyle}" Checked="ColorRadio_Checked"/>
                            <RadioButton GroupName="ThemeColors" Background="#10B981" Style="{StaticResource ColorRadioStyle}" Checked="ColorRadio_Checked"/>
                            <RadioButton GroupName="ThemeColors" Background="#EC4899" Style="{StaticResource ColorRadioStyle}" Checked="ColorRadio_Checked"/>
                            <RadioButton GroupName="ThemeColors" Background="#64748B" Style="{StaticResource ColorRadioStyle}" Checked="ColorRadio_Checked"/>
                        </StackPanel>

                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" x:Name="BtnSubmit" Content="Hoàn tất và Tạo lớp" Height="50" Background="#3B82F6" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnCreate_Click" Margin="0,0,15,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Grid.Column="1" x:Name="BtnCancel" Content="Huỷ bỏ" Height="50" Background="#F1F5F9" Foreground="#64748B" FontWeight="Bold" Cursor="Hand" Click="BtnCancel_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Button Content="← Quay lại" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20" Background="White" Foreground="#475569" BorderBrush="#E2E8F0" BorderThickness="1" Padding="15,8" Cursor="Hand" Click="BtnBack_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                        </Border.Effect>
                        <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</UserControl>