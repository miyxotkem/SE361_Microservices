<UserControl x:Class="e_learning_app.Views.SemesterSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding"      Value="28"/>
            <Setter Property="Margin"       Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputBox" TargetType="Border">
            <Setter Property="Background"   Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Height"       Value="44"/>
            <Setter Property="Padding"      Value="14,0"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="#94A3B8"/>
            <Setter Property="Margin"       Value="0,0,0,16"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SaveBtn" TargetType="Button">
            <Setter Property="Background"      Value="#3B82F6"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14" Padding="24,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background"      Value="#FEE2E2"/>
            <Setter Property="Foreground"      Value="#DC2626"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14" Padding="24,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FECACA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavItem" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding"      Value="16,10"/>
            <Setter Property="Margin"       Value="0,2"/>
            <Setter Property="Cursor"       Value="Hand"/>
        </Style>

        <Style x:Key="Toggle" TargetType="Border">
            <Setter Property="Width"        Value="44"/>
            <Setter Property="Height"       Value="24"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Cursor"       Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="32,20"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Thiết lập học kỳ" FontSize="22"
                               FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Cấu hình thông tin học kỳ, lịch thi và quy định điểm số"
                               FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F0FDF4" CornerRadius="10" Padding="12,6" Margin="0,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,8,0"/>
                            <TextBlock Text="Học kỳ 2 đang hoạt động" FontSize="12"
                                       Foreground="#16A34A" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="0,0,1,0" Padding="16,24">
                <StackPanel>
                    <TextBlock Text="THIẾT LẬP" Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource NavItem}" Background="#EFF6FF" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅" FontSize="15" Margin="0,0,10,0"/>
                            <TextBlock Text="Thông tin học kỳ" FontSize="13"
                                       Foreground="#3B82F6" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NavItem}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="15" Margin="0,0,10,0"/>
                            <TextBlock Text="Quy định điểm số" FontSize="13" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                    <Border Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NavItem}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" FontSize="15" Margin="0,0,10,0"/>
                            <TextBlock Text="Lịch kiểm tra - thi" FontSize="13" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                    <Border Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NavItem}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="15" Margin="0,0,10,0"/>
                            <TextBlock Text="Danh sách sinh viên" FontSize="13" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                    <Border Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NavItem}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔔" FontSize="15" Margin="0,0,10,0"/>
                            <TextBlock Text="Thông báo tự động" FontSize="13" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>

                    <Separator Margin="0,12" Background="#F1F5F9"/>
                    <TextBlock Text="HỆ THỐNG" Style="{StaticResource SectionLabel}"/>
                    <Border Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource NavItem}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔗" FontSize="15" Margin="0,0,10,0"/>
                            <TextBlock Text="Tích hợp hệ thống" FontSize="13" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="32,24,32,24">
                <StackPanel>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="36" Height="36" CornerRadius="10"
                                        Background="#EFF6FF" Margin="0,0,12,0">
                                    <TextBlock Text="📅" FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="Thông tin học kỳ" FontSize="16"
                                               FontWeight="Bold" Foreground="#1E293B"/>
                                    <TextBlock Text="Cấu hình thời gian và tên học kỳ hiện tại"
                                               FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Năm học" Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBox}">
                                        <Grid>
                                            <TextBlock Text="2024 - 2025" FontSize="13"
                                                       Foreground="#1E293B" VerticalAlignment="Center"/>
                                            <TextBlock Text="▾" FontSize="12" Foreground="#64748B"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Học kỳ" Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBox}">
                                        <Grid>
                                            <TextBlock Text="Học kỳ 2" FontSize="13"
                                                       Foreground="#1E293B" VerticalAlignment="Center"/>
                                            <TextBlock Text="▾" FontSize="12" Foreground="#64748B"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Ngày bắt đầu" Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBox}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📅" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="06/01/2025" FontSize="13"
                                                       Foreground="#1E293B" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Ngày kết thúc" Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBox}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📅" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="30/05/2025" FontSize="13"
                                                       Foreground="#1E293B" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="Trường / Khoa" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource InputBox}">
                                    <TextBlock Text="Đại học Công nghệ Thông tin - Khoa CNTT"
                                               FontSize="13" Foreground="#1E293B" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <Button Content="💾 Lưu thông tin học kỳ" Style="{StaticResource SaveBtn}"
                                    Width="220" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="36" Height="36" CornerRadius="10"
                                        Background="#F0FDF4" Margin="0,0,12,0">
                                    <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="Cơ cấu điểm số" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                                    <TextBlock Text="Thiết lập tỷ lệ điểm quá trình, giữa kỳ, cuối kỳ"
                                               FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Điểm quá trình (Bài tập + Chuyên cần)"
                                               Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBox}">
                                        <TextBlock Text="Bài tập hàng tuần, điểm danh, thảo luận"
                                                   FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Tỷ lệ (%)" Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBox}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="30" FontSize="18" FontWeight="Bold"
                                                       Foreground="#3B82F6" VerticalAlignment="Center"/>
                                            <TextBlock Text=" %" FontSize="13" Foreground="#64748B"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Điểm giữa kỳ" Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBox}">
                                        <TextBlock Text="Kiểm tra giữa học kỳ (tuần 8-9)"
                                                   FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Tỷ lệ (%)" Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBox}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="30" FontSize="18" FontWeight="Bold"
                                                       Foreground="#8B5CF6" VerticalAlignment="Center"/>
                                            <TextBlock Text=" %" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Điểm cuối kỳ" Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBox}">
                                        <TextBlock Text="Thi cuối học kỳ (tập trung)"
                                                   FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Tỷ lệ (%)" Style="{StaticResource FieldLabel}"/>
                                    <Border Style="{StaticResource InputBox}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="40" FontSize="18" FontWeight="Bold"
                                                       Foreground="#10B981" VerticalAlignment="Center"/>
                                            <TextBlock Text=" %" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Border Background="#F1F5F9" CornerRadius="8" Height="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="4*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#3B82F6" CornerRadius="8,0,0,8"/>
                                    <Border Grid.Column="1" Background="#8B5CF6"/>
                                    <Border Grid.Column="2" Background="#10B981" CornerRadius="0,8,8,0"/>
                                </Grid>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,16">
                                <Ellipse Width="8" Height="8" Fill="#3B82F6" Margin="0,0,6,0"/>
                                <TextBlock Text="QT 30%" FontSize="11" Foreground="#64748B" Margin="0,0,16,0"/>
                                <Ellipse Width="8" Height="8" Fill="#8B5CF6" Margin="0,0,6,0"/>
                                <TextBlock Text="GK 30%" FontSize="11" Foreground="#64748B" Margin="0,0,16,0"/>
                                <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0"/>
                                <TextBlock Text="CK 40%" FontSize="11" Foreground="#64748B"/>
                            </StackPanel>

                            <Button Content="💾 Lưu cơ cấu điểm" Style="{StaticResource SaveBtn}"
                                    Width="200" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="36" Height="36" CornerRadius="10"
                                        Background="#FFF7ED" Margin="0,0,12,0">
                                    <TextBlock Text="🔔" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="Thông báo tự động" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                                    <TextBlock Text="Bật/tắt các loại thông báo gửi tự động cho sinh viên"
                                               FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Border CornerRadius="12" Padding="16,12" Background="#F8FAFC" Margin="0,0,0,8">
                                <Grid>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Nhắc nhở nộp bài" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#1E293B"/>
                                        <TextBlock Text="Gửi nhắc nhở trước hạn nộp 24 giờ"
                                                   FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Border Style="{StaticResource Toggle}" Background="#3B82F6"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Ellipse Width="18" Height="18" Fill="White"
                                                 HorizontalAlignment="Right" Margin="0,0,3,0"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border CornerRadius="12" Padding="16,12" Background="#F8FAFC" Margin="0,0,0,8">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Thông báo điểm mới" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#1E293B"/>
                                        <TextBlock Text="Tự động gửi khi giảng viên nhập điểm xong"
                                                   FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Border Style="{StaticResource Toggle}" Background="#3B82F6"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Ellipse Width="18" Height="18" Fill="White"
                                                 HorizontalAlignment="Right" Margin="0,0,3,0"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border CornerRadius="12" Padding="16,12" Background="#F8FAFC" Margin="0,0,0,8">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Báo cáo hàng tuần cho giảng viên" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#1E293B"/>
                                        <TextBlock Text="Gửi tóm tắt hoạt động lớp vào thứ Hai hàng tuần"
                                                   FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Border Style="{StaticResource Toggle}" Background="#CBD5E1"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Ellipse Width="18" Height="18" Fill="White"
                                                 HorizontalAlignment="Left" Margin="3,0,0,0"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="20" BorderBrush="#FECACA"
                            BorderThickness="1.5" Padding="28" Margin="0,0,0,16">
                        <Border.Background>
                            <SolidColorBrush Color="#FFFBFB"/>
                        </Border.Background>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="⚠️" FontSize="18" Margin="0,0,10,0"/>
                                <TextBlock Text="Khu vực nguy hiểm" FontSize="16"
                                           FontWeight="Bold" Foreground="#DC2626"/>
                            </StackPanel>
                            <TextBlock Text="Các thao tác sau không thể hoàn tác. Hãy cân nhắc kỹ trước khi thực hiện."
                                       FontSize="13" Foreground="#EF4444"
                                       TextWrapping="Wrap" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="🗑️ Xoá toàn bộ dữ liệu học kỳ"
                                        Style="{StaticResource DangerBtn}"
                                        Width="240" Margin="0,0,12,0"/>
                                <Button Content="📦 Lưu trữ học kỳ"
                                        Style="{StaticResource DangerBtn}"
                                        Width="160"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>