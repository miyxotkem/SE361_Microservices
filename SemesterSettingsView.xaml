<UserControl x:Class="e_learning_app.Views.SemesterSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding"      Value="24"/>
            <Setter Property="Margin"       Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.05" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="Background"     Value="#F8FAFC"/>
            <Setter Property="BorderBrush"    Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="10"/>
            <Setter Property="Height"         Value="42"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#F8FAFC"/>
            <Setter Property="BorderBrush"      Value="#E2E8F0"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Height"           Value="42"/>
            <Setter Property="Padding"          Value="14,0"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Foreground"       Value="#1E293B"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin"     Value="0,0,0,18"/>
        </Style>
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WeightBox" TargetType="TextBox" BasedOn="{StaticResource FieldBox}">
            <Setter Property="Width"  Value="70"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30,30,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="⚙️  Thiết lập học kỳ" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Cấu hình các thông số cho học kỳ hiện tại và quy tắc tính điểm." FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnResetDefaults" Content="↺ Mặc định"
                            Background="#F1F5F9" Foreground="#475569"
                            Style="{StaticResource RoundBtn}" Padding="16,10" FontSize="13"
                            Margin="0,0,10,0" Click="BtnResetDefaults_Click"/>
                    <Button x:Name="BtnCancel" Content="Hủy thay đổi"
                            Background="#F1F5F9" Foreground="#475569"
                            Style="{StaticResource RoundBtn}" Padding="16,10" FontSize="13"
                            Margin="0,0,10,0" Click="BtnCancel_Click"/>
                    <Button x:Name="BtnSave" Content="💾  Lưu cài đặt"
                            Background="#3B82F6" Foreground="White"
                            Style="{StaticResource RoundBtn}" Padding="16,10" FontSize="13" FontWeight="SemiBold"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Grid>

            <!-- TWO-COLUMN CONTENT -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT -->
                <StackPanel Grid.Column="0">

                    <!-- Thông tin học kỳ -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="📅  Thông tin học kỳ" Style="{StaticResource SectionTitle}"/>

                            <TextBlock Text="Tên học kỳ" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtSemesterName" Style="{StaticResource FieldBox}"
                                     Margin="0,0,0,14" TextChanged="Field_Changed"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Ngày bắt đầu" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TxtStartDate" Style="{StaticResource FieldBox}"
                                             TextChanged="Field_Changed"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Ngày kết thúc" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TxtEndDate" Style="{StaticResource FieldBox}"
                                             TextChanged="Field_Changed"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Trường / Đơn vị" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtSchoolName" Style="{StaticResource FieldBox}"
                                     Margin="0,0,0,14" TextChanged="Field_Changed"/>

                            <TextBlock Text="Năm học" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtAcademicYear" Style="{StaticResource FieldBox}"
                                     TextChanged="Field_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- Điểm danh -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="✅  Cấu hình điểm danh" Style="{StaticResource SectionTitle}"/>

                            <TextBlock Text="Số buổi vắng tối đa (không phép)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtMaxAbsences" Style="{StaticResource FieldBox}"
                                     Margin="0,0,0,14" TextChanged="Field_Changed"/>

                            <TextBlock Text="Hành động khi vượt ngưỡng" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CbAbsenceAction" Height="42" FontSize="13"
                                      Margin="0,0,0,16"
                                      ItemsSource="{x:Null}"
                                      SelectionChanged="CbAbsenceAction_Changed"/>

                            <CheckBox x:Name="ChkEmailParent" Content="Gửi email phụ huynh khi học sinh vắng mặt"
                                      Margin="0,0,0,10" FontSize="13" Foreground="#1E293B" Tag="emailParent"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                            <CheckBox x:Name="ChkQRAttend" Content="Điểm danh tự động qua QR Code"
                                      Margin="0,0,0,10" FontSize="13" Foreground="#1E293B" Tag="qrAttendance"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                            <CheckBox x:Name="ChkOnlineExcuse" Content="Cho phép học sinh tự xin phép nghỉ online"
                                      FontSize="13" Foreground="#1E293B" Tag="onlineExcuse"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT -->
                <StackPanel Grid.Column="2">

                    <!-- Điểm số -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="📊  Cấu hình tính điểm" Style="{StaticResource SectionTitle}"/>

                            <TextBlock Text="Thang điểm" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CbGradeScale" Height="42" FontSize="13" Margin="0,0,0,14"
                                      SelectionChanged="Field_Changed"/>

                            <!-- Trọng số -->
                            <TextBlock Text="Trọng số điểm thành phần" Style="{StaticResource FieldLabel}"/>
                            <Border x:Name="TxtWeightSum" Background="#F8FAFC" CornerRadius="12" Padding="16" Margin="0,0,0,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Điểm miệng (hệ số 1)" FontSize="13" Foreground="#475569" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtWeightOral" Grid.Column="1" Style="{StaticResource WeightBox}"
                                                 Tag="oral" TextChanged="WeightBox_TextChanged"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Điểm 15 phút (hệ số 1)" FontSize="13" Foreground="#475569" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtWeight15" Grid.Column="1" Style="{StaticResource WeightBox}"
                                                 Tag="15min" TextChanged="WeightBox_TextChanged"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Kiểm tra 1 tiết (hệ số 2)" FontSize="13" Foreground="#475569" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtWeightMid" Grid.Column="1" Style="{StaticResource WeightBox}"
                                                 Tag="midterm" TextChanged="WeightBox_TextChanged"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Thi học kỳ (hệ số 3)" FontSize="13" Foreground="#475569" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtWeightFinal" Grid.Column="1" Style="{StaticResource WeightBox}"
                                                 Tag="final" TextChanged="WeightBox_TextChanged"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Weight total indicator -->
                            <Border x:Name="WeightSumBar" CornerRadius="8" Padding="12,8" Margin="0,8,0,14">
                                <TextBlock x:Name="TxtWeightSumMsg" FontSize="12" FontWeight="SemiBold"/>
                            </Border>

                            <TextBlock Text="Điểm đạt tối thiểu" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtMinPass" Style="{StaticResource FieldBox}" Margin="0,0,0,14"
                                     TextChanged="Field_Changed"/>

                            <CheckBox x:Name="ChkRoundHalf" Content="Làm tròn điểm tới 0.5"
                                      Margin="0,0,0,10" FontSize="13" Foreground="#1E293B" Tag="roundHalf"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                            <CheckBox x:Name="ChkGradeLabel" Content="Hiển thị xếp loại (Giỏi / Khá / TB / Yếu)"
                                      Margin="0,0,0,10" FontSize="13" Foreground="#1E293B" Tag="gradeLabel"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                            <CheckBox x:Name="ChkStudentView" Content="Cho phép học sinh xem điểm online"
                                      FontSize="13" Foreground="#1E293B" Tag="studentView"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- Tích hợp -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="🔗  Tích hợp &amp; Thông báo" Style="{StaticResource SectionTitle}"/>
                            <CheckBox x:Name="ChkWeeklyEmail" Content="Gửi tổng kết điểm qua Email hàng tuần"
                                      Margin="0,0,0,12" FontSize="13" Foreground="#1E293B" Tag="weeklyEmail"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                            <CheckBox x:Name="ChkGoogleClass" Content="Kết nối Google Classroom"
                                      Margin="0,0,0,12" FontSize="13" Foreground="#1E293B" Tag="googleClassroom"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                            <CheckBox x:Name="ChkGoogleCal" Content="Đồng bộ lịch với Google Calendar"
                                      Margin="0,0,0,12" FontSize="13" Foreground="#1E293B" Tag="googleCalendar"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                            <CheckBox x:Name="ChkMobilePush" Content="Nhận thông báo push trên điện thoại"
                                      Margin="0,0,0,16" FontSize="13" Foreground="#1E293B" Tag="mobilePush"
                                      Checked="Toggle_Changed" Unchecked="Toggle_Changed"/>
                            <Separator Background="#F1F5F9" Margin="0,0,0,14"/>
                            <TextBlock Text="Ngôn ngữ hệ thống" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CbLanguage" Height="42" FontSize="13"
                                      SelectionChanged="Field_Changed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
