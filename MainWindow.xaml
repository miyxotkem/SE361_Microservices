<Window x:Class="e_learning_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EduFlow" Height="900" Width="1500"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderThickness="0,0,1,0" BorderBrush="#E2E8F0">
            <Grid Margin="10,30,10,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Button x:Name="btnDashBoard" Content="🏠 Bảng điều khiển" Style="{StaticResource NavButtonStyle}" Click="NavDashboard_Click"/>
                    <Button Content="🎓 Lớp học của tôi" Style="{StaticResource NavButtonStyle}" Click="NavClasses_Click"/>
                    <Button Content="⚙️ Thiết lập" Style="{StaticResource NavButtonStyle}" Click="NavSemestersettings_Click"/>
                </StackPanel>

                <Button Grid.Row="1" Click="OpenProfile_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="35" Height="35" CornerRadius="10" Background="#3B82F6"/>

                        <TextBlock Text="{Binding FullName}" 
                   VerticalAlignment="Center" 
                   Margin="10,0"
                   FontWeight="Medium"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1" x:Name="MainContentArea" />
    </Grid>
</Window>