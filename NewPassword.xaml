<UserControl x:Class="e_learning_app.NewPassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Background="#FAFAFA">
        <TextBlock Text="Step 2: Set New Password" FontWeight="Bold" Margin="0,0,0,10"/>

        <TextBlock Text="New Password:" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtNewPassword" Height="25"/>

        <TextBlock Text="Confirm New Password:" Margin="0,10,0,5"/>
        <PasswordBox x:Name="txtConfirmPassword" Height="25"/>

        <Button Content="Update Password" Width="120" HorizontalAlignment="Right" Margin="0,15,0,0" Click="btnUpdate_Click"/>
    </StackPanel>
</UserControl>