<Window x:Class="e_learning_app.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập - EduFlow" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="Transparent"
        AllowsTransparency="True" WindowStyle="None">

    <Border CornerRadius="20" Background="White" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.15" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="450"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" CornerRadius="20,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4F46E5" Offset="0"/>
                        <GradientStop Color="#3B82F6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="50">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="60" Height="60" Background="White" CornerRadius="15" HorizontalAlignment="Left" Margin="0,0,0,30">
                            <TextBlock Text="E" Foreground="#3B82F6" FontSize="35" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="EduSmart" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,0,0,0"/>
                        <TextBlock Text="Hành trình vạn dặm bắt đầu từ một khóa học hay." 
                                   FontSize="18" Foreground="#D1E4FF" TextWrapping="Wrap" LineHeight="26"/>

                        <StackPanel Orientation="Horizontal" Margin="0,40,0,0">
                            <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,8,0"/>
                            <Ellipse Width="8" Height="8" Fill="#89B4FB" Margin="0,0,8,0"/>
                            <Ellipse Width="8" Height="8" Fill="#89B4FB"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="© 2026 EduSmart Team" VerticalAlignment="Bottom" Foreground="#A0C4FF" FontSize="12"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="Transparent" Padding="50,40">
                <Border Grid.Column="1" Background="Transparent" Padding="20,20">
                    <ContentControl x:Name="MainContentHolder" />
                </Border>
            </Border>

            <Button Grid.Column="1" Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                    Click="btnclose"
                    Margin="20" Background="Transparent" BorderThickness="0" Foreground="#94A3B8" FontSize="18" Cursor="Hand"/>
        </Grid>
    </Border>
</Window>