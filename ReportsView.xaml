<UserControl x:Class="e_learning_app.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding"    Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30,30,30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="📊  Báo cáo &amp; Điểm số" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Thống kê kết quả học tập chi tiết theo từng lớp và học sinh." FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnSemester" Background="White" Style="{StaticResource RoundBtn}"
                            Padding="14,0" Height="40" Margin="0,0,10,0" Click="BtnSemester_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📅" FontSize="13"/>
                            <TextBlock x:Name="TxtSemesterLabel" Text="  Học kỳ 2 – 2024" FontSize="13" Foreground="#475569" Margin="4,0"/>
                            <TextBlock Text="▾" FontSize="10" Foreground="#94A3B8" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnPrint" Content="🖨️  In" Background="#F1F5F9" Foreground="#475569"
                            Style="{StaticResource RoundBtn}" Padding="14,10" FontSize="13"
                            Margin="0,0,10,0" Click="BtnPrint_Click"/>
                    <Button x:Name="BtnExport" Content="📤  Xuất CSV" Background="#3B82F6" Foreground="White"
                            Style="{StaticResource RoundBtn}" Padding="14,10" FontSize="13" FontWeight="SemiBold"
                            Click="BtnExportReport_Click"/>
                </StackPanel>
            </Grid>

            <!-- SUMMARY STAT CARDS -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Điểm trung bình lớp" FontSize="12" Foreground="#64748B"/>
                        <TextBlock x:Name="TxtOverallAvg" FontSize="34" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                        <Border x:Name="BarAvg" Height="6" CornerRadius="3" Margin="0,10,0,0">
                            <Border.Background>
                                <SolidColorBrush Color="#3B82F6"/>
                            </Border.Background>
                        </Border>
                        <TextBlock x:Name="TxtAvgNote" FontSize="11" Foreground="#22C55E" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Tỷ lệ đạt" FontSize="12" Foreground="#64748B"/>
                        <TextBlock x:Name="TxtPassRate" FontSize="34" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                        <Border x:Name="BarPass" Height="6" CornerRadius="3" Margin="0,10,0,0" Background="#10B981"/>
                        <TextBlock x:Name="TxtPassNote" FontSize="11" Foreground="#64748B" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Tỷ lệ xuất sắc" FontSize="12" Foreground="#64748B"/>
                        <TextBlock x:Name="TxtExcelRate" FontSize="34" FontWeight="Bold" Foreground="#1E293B" Margin="0,8,0,0"/>
                        <Border x:Name="BarExcel" Height="6" CornerRadius="3" Margin="0,10,0,0" Background="#F59E0B"/>
                        <TextBlock x:Name="TxtExcelNote" FontSize="11" Foreground="#64748B" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="6" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Tỷ lệ yếu / kém" FontSize="12" Foreground="#64748B"/>
                        <TextBlock x:Name="TxtWeakRate" FontSize="34" FontWeight="Bold" Foreground="#EF4444" Margin="0,8,0,0"/>
                        <Border x:Name="BarWeak" Height="6" CornerRadius="3" Margin="0,10,0,0" Background="#FCA5A5"/>
                        <TextBlock x:Name="TxtWeakNote" FontSize="11" Foreground="#EF4444" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- TABLE + CHART -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Grade table (dynamic) -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="Bảng điểm theo lớp" FontWeight="Bold" FontSize="15" Foreground="#1E293B"/>
                            <Button x:Name="BtnViewAll" Content="Xem tất cả →" Background="Transparent"
                                    BorderThickness="0" Foreground="#3B82F6" FontSize="12" FontWeight="SemiBold"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"
                                    Click="BtnViewAllClasses_Click"/>
                        </Grid>
                        <!-- Table header -->
                        <Border Background="#F8FAFC" CornerRadius="8">
                            <Grid Height="36">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Lớp học" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" Margin="14,0"/>
                                <TextBlock Grid.Column="1" Text="Sĩ số"   FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Điểm TB" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="Đạt"     FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Xuất sắc" FontSize="12" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <!-- Dynamic rows -->
                        <StackPanel x:Name="TableRowsPanel"/>
                    </StackPanel>
                </Border>

                <!-- Right panel: distribution + top students -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Phân bố điểm số" FontWeight="Bold" FontSize="15" Foreground="#1E293B" Margin="0,0,0,20"/>
                        <StackPanel x:Name="DistributionPanel"/>
                        <Separator Background="#F1F5F9" Margin="0,20"/>
                        <TextBlock Text="🏆  Top học sinh xuất sắc" FontWeight="SemiBold" FontSize="13" Foreground="#1E293B" Margin="0,0,0,12"/>
                        <StackPanel x:Name="TopStudentsPanel"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
