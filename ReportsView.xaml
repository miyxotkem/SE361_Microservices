<UserControl x:Class="e_learning_app.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding"      Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabBtn" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding"      Value="20,8"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Margin"       Value="0,0,6,0"/>
        </Style>

        <Style x:Key="GradeRow" TargetType="Border">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding"      Value="12,10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExportBtn" TargetType="Button">
            <Setter Property="Background"      Value="#EFF6FF"/>
            <Setter Property="Foreground"      Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="32,20"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Báo cáo &amp; Điểm số" FontSize="22"
                               FontWeight="Bold" Foreground="#1E293B"/>
                    <TextBlock Text="Theo dõi kết quả học tập của sinh viên toàn bộ lớp"
                               FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📊 Xuất Excel" Style="{StaticResource ExportBtn}" Margin="0,0,10,0" Width="130"/>
                    <Button Content="📄 Xuất PDF" Style="{StaticResource ExportBtn}" Width="120"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24,32,24">

                <!-- Class Selector Tabs -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Style="{StaticResource TabBtn}" Background="#3B82F6">
                        <TextBlock Text="💻 Lập trình Web" FontSize="12"
                                   Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                    <Border Style="{StaticResource TabBtn}" Background="White">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                        </Border.Effect>
                        <TextBlock Text="🗃️ Cơ sở dữ liệu" FontSize="12" Foreground="#64748B"/>
                    </Border>
                    <Border Style="{StaticResource TabBtn}" Background="White">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                        </Border.Effect>
                        <TextBlock Text="🤖 Trí tuệ nhân tạo" FontSize="12" Foreground="#64748B"/>
                    </Border>
                    <Border Style="{StaticResource TabBtn}" Background="White">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                        </Border.Effect>
                        <TextBlock Text="🔢 Giải tích" FontSize="12" Foreground="#64748B"/>
                    </Border>
                </StackPanel>

                <!-- Summary Stats Row -->
                <UniformGrid Columns="5" Margin="0,0,0,20">
                    <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="8.2" FontSize="30" FontWeight="Bold"
                                       Foreground="#3B82F6" HorizontalAlignment="Center"/>
                            <TextBlock Text="Điểm TB lớp" FontSize="12"
                                       Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="5,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="10.0" FontSize="30" FontWeight="Bold"
                                       Foreground="#22C55E" HorizontalAlignment="Center"/>
                            <TextBlock Text="Điểm cao nhất" FontSize="12"
                                       Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="5,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="4.5" FontSize="30" FontWeight="Bold"
                                       Foreground="#EF4444" HorizontalAlignment="Center"/>
                            <TextBlock Text="Điểm thấp nhất" FontSize="12"
                                       Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="5,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="94%" FontSize="30" FontWeight="Bold"
                                       Foreground="#10B981" HorizontalAlignment="Center"/>
                            <TextBlock Text="Tỉ lệ đạt" FontSize="12"
                                       Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}" Margin="10,0,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="2" FontSize="30" FontWeight="Bold"
                                       Foreground="#F59E0B" HorizontalAlignment="Center"/>
                            <TextBlock Text="SV không đạt" FontSize="12"
                                       Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Chart + Distribution -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- Grade Distribution Chart (Visual bar chart using WPF) -->
                    <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Phân phối điểm số" FontSize="16"
                                       FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>
                            <!-- Bar Chart Area -->
                            <Grid Height="180">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Y Axis Labels -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                    <TextBlock Text="12" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Top"/>
                                    <TextBlock Text="9" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <TextBlock Text="6" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <TextBlock Text="3" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <TextBlock Text="0" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Bottom"/>
                                </StackPanel>
                                <!-- Bars -->
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="24"/>
                                    </Grid.RowDefinitions>
                                    <!-- Horizontal grid lines -->
                                    <Canvas Grid.Row="0">
                                        <Line X1="0" Y1="0" X2="500" Y2="0" Stroke="#F1F5F9" StrokeThickness="1"/>
                                        <Line X1="0" Y1="40" X2="500" Y2="40" Stroke="#F1F5F9" StrokeThickness="1"/>
                                        <Line X1="0" Y1="80" X2="500" Y2="80" Stroke="#F1F5F9" StrokeThickness="1"/>
                                        <Line X1="0" Y1="120" X2="500" Y2="120" Stroke="#F1F5F9" StrokeThickness="1"/>
                                        <Line X1="0" Y1="156" X2="500" Y2="156" Stroke="#E2E8F0" StrokeThickness="1.5"/>
                                    </Canvas>
                                    <!-- Bars (simulated with Uniform grid + Borders) -->
                                    <UniformGrid Grid.Row="0" Columns="10"
                                                 VerticalAlignment="Bottom" Margin="10,0">
                                        <!-- 0-1 -->
                                        <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                            <Border Background="#EF4444" CornerRadius="4,4,0,0" Height="8"/>
                                        </StackPanel>
                                        <!-- 1-2 -->
                                        <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                            <Border Background="#EF4444" CornerRadius="4,4,0,0" Height="0"/>
                                        </StackPanel>
                                        <!-- 2-3 -->
                                        <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                            <Border Background="#F59E0B" CornerRadius="4,4,0,0" Height="24"/>
                                        </StackPanel>
                                        <!-- 3-4 -->
                                        <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                            <Border Background="#F59E0B" CornerRadius="4,4,0,0" Height="32"/>
                                        </StackPanel>
                                        <!-- 4-5 -->
                                        <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                            <Border Background="#3B82F6" CornerRadius="4,4,0,0" Height="48"/>
                                        </StackPanel>
                                        <!-- 5-6 -->
                                        <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                            <Border Background="#3B82F6" CornerRadius="4,4,0,0" Height="80"/>
                                        </StackPanel>
                                        <!-- 6-7 -->
                                        <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                            <Border Background="#3B82F6" CornerRadius="4,4,0,0" Height="130"/>
                                        </StackPanel>
                                        <!-- 7-8 -->
                                        <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                            <Border Background="#3B82F6" CornerRadius="4,4,0,0" Height="156"/>
                                        </StackPanel>
                                        <!-- 8-9 -->
                                        <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                            <Border Background="#10B981" CornerRadius="4,4,0,0" Height="104"/>
                                        </StackPanel>
                                        <!-- 9-10 -->
                                        <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                            <Border Background="#10B981" CornerRadius="4,4,0,0" Height="56"/>
                                        </StackPanel>
                                    </UniformGrid>
                                    <!-- X Axis Labels -->
                                    <UniformGrid Grid.Row="1" Columns="10" Margin="10,4">
                                        <TextBlock Text="0-1" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="1-2" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="2-3" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="3-4" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="4-5" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="5-6" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="6-7" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="7-8" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="8-9" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                        <TextBlock Text="9-10" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    </UniformGrid>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Grade Breakdown -->
                    <Border Grid.Column="1" Style="{StaticResource Card}" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Xếp loại sinh viên" FontSize="16"
                                       FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,16"/>
                            <StackPanel>
                                <Grid Margin="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Xuất sắc (9-10)" FontSize="12" Foreground="#1E293B" FontWeight="SemiBold"/>
                                        <Border Background="#F1F5F9" CornerRadius="4" Height="6" Margin="0,6,0,0">
                                            <Border Background="#10B981" CornerRadius="4" HorizontalAlignment="Left" Width="74"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="5 SV" FontSize="12"
                                               Foreground="#10B981" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Giỏi (8-8.9)" FontSize="12" Foreground="#1E293B" FontWeight="SemiBold"/>
                                        <Border Background="#F1F5F9" CornerRadius="4" Height="6" Margin="0,6,0,0">
                                            <Border Background="#3B82F6" CornerRadius="4" HorizontalAlignment="Left" Width="148"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="10 SV" FontSize="12"
                                               Foreground="#3B82F6" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Khá (7-7.9)" FontSize="12" Foreground="#1E293B" FontWeight="SemiBold"/>
                                        <Border Background="#F1F5F9" CornerRadius="4" Height="6" Margin="0,6,0,0">
                                            <Border Background="#8B5CF6" CornerRadius="4" HorizontalAlignment="Left" Width="185"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="12 SV" FontSize="12"
                                               Foreground="#8B5CF6" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Trung bình (5-6.9)" FontSize="12" Foreground="#1E293B" FontWeight="SemiBold"/>
                                        <Border Background="#F1F5F9" CornerRadius="4" Height="6" Margin="0,6,0,0">
                                            <Border Background="#F59E0B" CornerRadius="4" HorizontalAlignment="Left" Width="74"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="3 SV" FontSize="12"
                                               Foreground="#F59E0B" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                                <Grid Margin="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Không đạt (&lt; 5)" FontSize="12" Foreground="#1E293B" FontWeight="SemiBold"/>
                                        <Border Background="#F1F5F9" CornerRadius="4" Height="6" Margin="0,6,0,0">
                                            <Border Background="#EF4444" CornerRadius="4" HorizontalAlignment="Left" Width="37"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="2 SV" FontSize="12"
                                               Foreground="#EF4444" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Grade Table -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="Bảng điểm sinh viên" FontSize="16"
                                       FontWeight="Bold" Foreground="#1E293B"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Background="#F8FAFC" CornerRadius="10" Padding="12,6" Margin="0,0,10,0" Cursor="Hand">
                                    <TextBlock Text="🔍 Tìm kiếm" FontSize="12" Foreground="#64748B"/>
                                </Border>
                                <Border Background="#F8FAFC" CornerRadius="10" Padding="12,6" Cursor="Hand">
                                    <TextBlock Text="↕ Sắp xếp" FontSize="12" Foreground="#64748B"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Table Header -->
                        <Border Background="#F8FAFC" CornerRadius="12" Padding="16,10" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                <TextBlock Grid.Column="1" Text="HỌ VÀ TÊN" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                <TextBlock Grid.Column="2" Text="MSSV" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                                <TextBlock Grid.Column="3" Text="QUÁ TRÌNH" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="GIỮA KỲ" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="CUỐI KỲ" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="TỔNG KẾT" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="7" Text="XẾP LOẠI" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Row 1 -->
                        <Border Style="{StaticResource GradeRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="1" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="30" Height="30" CornerRadius="8" Background="#EFF6FF" Margin="0,0,10,0">
                                        <TextBlock Text="AN" FontSize="10" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Nguyễn Thị An" FontSize="13" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="20110001" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="9.5" FontSize="14" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="8.0" FontSize="14" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="9.0" FontSize="14" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="9.0" FontSize="16" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border Grid.Column="7" Background="#F0FDF4" CornerRadius="8" Padding="10,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="Xuất sắc" FontSize="11" Foreground="#16A34A" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Row 2 -->
                        <Border Style="{StaticResource GradeRow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="2" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="30" Height="30" CornerRadius="8" Background="#FDF4FF" Margin="0,0,10,0">
                                        <TextBlock Text="BM" FontSize="10" FontWeight="Bold" Foreground="#9333EA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Trần Văn Bình Minh" FontSize="13" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="20110015" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="7.0" FontSize="14" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="8.5" FontSize="14" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="8.0" FontSize="14" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="7.9" FontSize="16" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border Grid.Column="7" Background="#EFF6FF" CornerRadius="8" Padding="10,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="Khá" FontSize="11" Foreground="#3B82F6" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Row 3 - Failed -->
                        <Border Style="{StaticResource GradeRow}" Background="#FEF2F2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="3" FontSize="13" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="30" Height="30" CornerRadius="8" Background="#FEE2E2" Margin="0,0,10,0">
                                        <TextBlock Text="CH" FontSize="10" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Lê Thị Cẩm Hà" FontSize="13" Foreground="#1E293B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="20110023" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="4.0" FontSize="14" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="3.5" FontSize="14" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="4.5" FontSize="14" FontWeight="Bold" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
