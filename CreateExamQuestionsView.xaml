<UserControl x:Class="e_learning_app.CreateExamQuestionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="FieldLabelStyle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionHeaderStyle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,20,0,14"/>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Header -->
        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,20" VerticalAlignment="Top" Height="95">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="✏️ Soạn Câu Hỏi Bài Thi" FontSize="26" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtExamInfo" Text="Đang tạo bài thi: ..." FontSize="13" Foreground="#64748B"/>
                </StackPanel>

                <Button x:Name="BtnBack" Grid.Column="1" Content="← Quay Lại Thiết Lập" Background="White" Foreground="#475569" BorderBrush="#E2E8F0" BorderThickness="1" Padding="14,10" Cursor="Hand" Click="BtnBack_Click" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid VerticalAlignment="Stretch" Margin="24,100,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Preview Questions List -->
            <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="📋 Danh Sách Câu Hỏi" FontSize="18" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        <Border Background="#EFF6FF" CornerRadius="12" Padding="10,4" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtQuestionCount" Text="0 câu" FontSize="12" FontWeight="Bold" Foreground="#3B82F6"/>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <!-- Questions List -->
                        <ScrollViewer x:Name="ManualListScroller" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="QuestionsListPanel">
                                <!-- Items will be generated dynamically -->
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Button Grid.Row="2" x:Name="BtnSubmit" Content="✅ Hoàn Tất Tạo Bài Thi" Height="50" Background="#10B981" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnSubmit_Click" FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#059669"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- RIGHT: Add Question Form -->
            <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Import Section -->
                        <Border Background="#F8FAFC" CornerRadius="12" Padding="16" Margin="0,0,0,24" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="📥 Import từ Excel (.xlsx)" FontWeight="Bold" FontSize="14" Foreground="#1E293B" VerticalAlignment="Center"/>
                                    <Button x:Name="BtnDownloadTemplate" Content="⬇️ Tải file mẫu" HorizontalAlignment="Right" Background="Transparent" Foreground="#3B82F6" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="BtnDownloadTemplate_Click"/>
                                </Grid>
                                
                                <!-- Drag Drop Area -->
                                <Border x:Name="DropZone" BorderBrush="#CBD5E1" BorderThickness="2" CornerRadius="8" Height="100" Background="White" AllowDrop="True" DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave" Drop="DropZone_Drop" MouseLeftButtonDown="DropZone_MouseLeftButtonDown" Cursor="Hand">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtDropIcon" Text="📄" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Kéo thả file Excel vào đây" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="hoặc click để chọn file" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Progress Panel -->
                                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,16,0,0">
                                    <TextBlock x:Name="TxtImportStatus" Text="Đang xử lý dữ liệu..." FontSize="12" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <ProgressBar x:Name="ImportProgress" Height="6" Minimum="0" Maximum="100" Value="0" Foreground="#10B981" BorderThickness="0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Hoặc Thêm Thủ Công:" FontWeight="Bold" FontSize="14" Foreground="#1E293B" Margin="0,0,0,16"/>

                        <!-- Question Content -->
                        <TextBlock Text="Nội dung câu hỏi" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="TxtContent" Style="{StaticResource ModernTextBox}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Margin="0,0,0,16"/>

                        <!-- Points -->
                        <TextBlock Text="Điểm số" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="TxtPoints" Style="{StaticResource ModernTextBox}" Height="40" Text="1" Margin="0,0,0,16"/>

                        <!-- Options -->
                        <TextBlock Text="Các đáp án (Chọn Radio cho đáp án đúng)" Style="{StaticResource FieldLabelStyle}"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="RbOptA" GroupName="CorrectAnswer" Content="A" IsChecked="True" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                            <TextBox Grid.Column="1" x:Name="TxtOptA" Style="{StaticResource ModernTextBox}" Height="40"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="RbOptB" GroupName="CorrectAnswer" Content="B" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                            <TextBox Grid.Column="1" x:Name="TxtOptB" Style="{StaticResource ModernTextBox}" Height="40"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="RbOptC" GroupName="CorrectAnswer" Content="C" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                            <TextBox Grid.Column="1" x:Name="TxtOptC" Style="{StaticResource ModernTextBox}" Height="40"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="RbOptD" GroupName="CorrectAnswer" Content="D" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                            <TextBox Grid.Column="1" x:Name="TxtOptD" Style="{StaticResource ModernTextBox}" Height="40"/>
                        </Grid>

                        <Button x:Name="BtnAddManual" Content="➕ Thêm Câu Hỏi" Height="42" Background="#3B82F6" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnAddManual_Click" FontSize="13">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
