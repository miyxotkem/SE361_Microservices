<UserControl x:Class="e_learning_app.ProfileManage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded"
             Background="White">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Full Name:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox x:Name="txtFullName" Grid.Row="0" Grid.Column="1" Height="25" Margin="0,0,0,10" Padding="2"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Email:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox x:Name="txtEmail" Grid.Row="1" Grid.Column="1" Height="25" Margin="0,0,0,10" Padding="2"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Phone:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox x:Name="txtPhone" Grid.Row="2" Grid.Column="1" Height="25" Margin="0,0,0,10" Padding="2"/>

        <Label Grid.Row="3" Grid.Column="0" Content="Username:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox x:Name="txtUsername" Grid.Row="3" Grid.Column="1" Height="25" Margin="0,0,0,10" Padding="2"/>

        <Label Grid.Row="4" Grid.Column="0" Content="Role:" VerticalAlignment="Center" Margin="0,0,10,10"/>
        <TextBox x:Name="txtRole" Grid.Row="4" Grid.Column="1" Height="25" Margin="0,0,0,10" Padding="2"/>

        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnChangePassword" Content="Change Password" Width="120" Height="30" Margin="0,0,10,0" Click="btnChangePassword_Click"/>
            <Button x:Name="btnSave" Content="Save Changes" Width="100" Height="30" Click="btnSave_Click" Background="#FF0078D7" Foreground="White"/>
        </StackPanel>

        <ContentControl x:Name="PasswordViewContainer" Grid.Row="6" Grid.ColumnSpan="2" Margin="0,20,0,0"/>
    </Grid>
</UserControl>