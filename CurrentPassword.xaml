<UserControl x:Class="e_learning_app.CurrentPassword"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Background="#FAFAFA">
        <TextBlock Text="Step 1: Verify Identity" FontWeight="Bold" Margin="0,0,0,10"/>
        <TextBlock Text="Current Password:" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtCurrentPassword" Height="25"/>
        <Button Content="Next" Width="75" HorizontalAlignment="Right" Margin="0,15,0,0" Click="btnNext_Click"/>
    </StackPanel>
</UserControl>