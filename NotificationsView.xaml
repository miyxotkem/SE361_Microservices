<UserControl x:Class="e_learning_app.Views.NotificationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="FilterBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#64748B"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,30,30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="🔔  Thông báo lớp" FontSize="24" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Quản lý và gửi thông báo tới học sinh và phụ huynh." FontSize="13" Foreground="#64748B" Margin="0,6,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="BtnMarkAllRead" Content="✓ Đánh dấu đã đọc"
                        Background="#F1F5F9" Foreground="#475569"
                        Style="{StaticResource RoundBtn}" Padding="14,9" FontSize="13"
                        Margin="0,0,10,0" Click="BtnMarkAllRead_Click"/>
                <Button x:Name="BtnCreateNotif" Content="+ Tạo thông báo mới"
                        Background="#3B82F6" Foreground="White"
                        Style="{StaticResource RoundBtn}" Padding="14,9" FontSize="13" FontWeight="SemiBold"
                        Click="BtnCreateNotif_Click"/>
            </StackPanel>
        </Grid>

        <!-- FILTER TABS -->
        <Border Grid.Row="2" Background="White" CornerRadius="14" Padding="6">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.05" Color="Black"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnFilterAll"    Style="{StaticResource FilterBtn}" Tag="all"
                        Background="#EFF6FF" Foreground="#3B82F6" FontWeight="SemiBold"
                        Click="BtnFilter_Click"/>
                <Button x:Name="BtnFilterUnread" Style="{StaticResource FilterBtn}" Tag="unread"
                        Margin="4,0" Click="BtnFilter_Click"/>
                <Button x:Name="BtnFilterSent"   Style="{StaticResource FilterBtn}" Tag="sent"
                        Margin="0,0,4,0" Click="BtnFilter_Click"/>
                <Button x:Name="BtnFilterSystem" Style="{StaticResource FilterBtn}" Tag="system"
                        Click="BtnFilter_Click"/>
            </StackPanel>
        </Border>

        <!-- NOTIFICATION LIST (dynamic) -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="NotifListPanel"/>
        </ScrollViewer>
    </Grid>
</UserControl>
