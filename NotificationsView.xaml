<UserControl x:Class="e_learning_app.Views.NotificationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5"
             FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <UserControl.Resources>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#3B82F6"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="18,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NotifCard" TargetType="Border">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding"      Value="20,16"/>
            <Setter Property="Margin"       Value="0,0,0,10"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.10" Color="#3B82F6"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="UnreadCard" TargetType="Border">
            <Setter Property="Background"    Value="#FAFCFF"/>
            <Setter Property="CornerRadius"  Value="16"/>
            <Setter Property="Padding"       Value="20,16"/>
            <Setter Property="Margin"        Value="0,0,0,10"/>
            <Setter Property="BorderBrush"   Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.06" Color="#3B82F6"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="32,20"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Thông báo lớp" FontSize="22"
                                   FontWeight="Bold" Foreground="#1E293B"/>
                        <Border Background="#EF4444" CornerRadius="10"
                                Padding="10,3" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="5 mới" FontSize="11"
                                       Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Gửi thông báo đến toàn bộ lớp hoặc sinh viên cụ thể"
                               FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#F8FAFC" CornerRadius="12" Padding="14,0"
                            Height="40" Margin="0,0,10,0" Cursor="Hand">
                        <TextBlock Text="✓ Đánh dấu tất cả đã đọc" FontSize="13"
                                   Foreground="#64748B" VerticalAlignment="Center"/>
                    </Border>
                    <Button Content="+ Tạo thông báo" Style="{StaticResource PrimaryBtn}"
                            Width="160"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Notification Feed -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="32,24,20,24">
                <StackPanel>

                    <!-- Section: Hôm nay -->
                    <TextBlock Text="HÔM NAY" FontSize="11" FontWeight="Bold"
                               Foreground="#94A3B8" Margin="0,0,0,12"/>

                    <!-- Unread Notification -->
                    <Border Style="{StaticResource UnreadCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Unread Dot + Icon -->
                            <Grid Grid.Column="0" Margin="0,0,16,0">
                                <Border Width="46" Height="46" CornerRadius="14"
                                        Background="#FFF7ED">
                                    <TextBlock Text="📢" FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <Ellipse Width="10" Height="10" Fill="#3B82F6"
                                         HorizontalAlignment="Right" VerticalAlignment="Top"
                                         Margin="0,-2,-2,0"/>
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border Background="#EFF6FF" CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                        <TextBlock Text="Lập trình Web" FontSize="10"
                                                   Foreground="#3B82F6" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="Thay đổi phòng học" FontSize="10"
                                               Foreground="#64748B"/>
                                </StackPanel>
                                <TextBlock Text="Thay đổi phòng học tuần này"
                                           FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock Text="Buổi học ngày 04/04 sẽ được dời sang phòng C102 do phòng B204 đang sửa chữa hệ thống điện."
                                           FontSize="13" Foreground="#64748B"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="👁 128 lượt xem" FontSize="11" Foreground="#94A3B8"/>
                                    <TextBlock Text="  •  " Foreground="#CBD5E1" FontSize="11"/>
                                    <TextBlock Text="💬 4 phản hồi" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="16,0,0,0" HorizontalAlignment="Right">
                                <TextBlock Text="09:15" FontSize="11" Foreground="#94A3B8"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Text="✏️" FontSize="14" Cursor="Hand"
                                           HorizontalAlignment="Right" Margin="0,12,0,4"/>
                                <TextBlock Text="🗑️" FontSize="14" Cursor="Hand"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Unread Notification 2 -->
                    <Border Style="{StaticResource UnreadCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0,0,16,0">
                                <Border Width="46" Height="46" CornerRadius="14" Background="#F0FDF4">
                                    <TextBlock Text="📝" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Ellipse Width="10" Height="10" Fill="#3B82F6"
                                         HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0"/>
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border Background="#F0FDF4" CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                        <TextBlock Text="Cơ sở dữ liệu" FontSize="10" Foreground="#16A34A" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="Bài tập mới" FontSize="10" Foreground="#64748B"/>
                                </StackPanel>
                                <TextBlock Text="Bài tập tuần 10 đã được đăng"
                                           FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock Text="Sinh viên hoàn thành bài tập về lập trình SQL nâng cao trước 11:59PM ngày 08/04/2025."
                                           FontSize="13" Foreground="#64748B" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="👁 96 lượt xem" FontSize="11" Foreground="#94A3B8"/>
                                    <TextBlock Text="  •  " Foreground="#CBD5E1" FontSize="11"/>
                                    <TextBlock Text="💬 1 phản hồi" FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="16,0,0,0" HorizontalAlignment="Right">
                                <TextBlock Text="08:30" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                                <TextBlock Text="✏️" FontSize="14" Cursor="Hand" HorizontalAlignment="Right" Margin="0,12,0,4"/>
                                <TextBlock Text="🗑️" FontSize="14" Cursor="Hand" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Section: Hôm qua -->
                    <TextBlock Text="HÔM QUA" FontSize="11" FontWeight="Bold"
                               Foreground="#94A3B8" Margin="0,20,0,12"/>

                    <!-- Read Notification -->
                    <Border Style="{StaticResource NotifCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="46" Height="46" CornerRadius="14"
                                    Background="#FDF4FF" Margin="0,0,16,0">
                                <TextBlock Text="🔔" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border Background="#FDF4FF" CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                        <TextBlock Text="Tất cả lớp" FontSize="10" Foreground="#9333EA" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="Nhắc nhở" FontSize="10" Foreground="#64748B"/>
                                </StackPanel>
                                <TextBlock Text="Nhắc nhở nộp đồ án giữa kỳ"
                                           FontSize="14" FontWeight="SemiBold" Foreground="#64748B"/>
                                <TextBlock Text="Hạn nộp đồ án giữa kỳ còn 3 ngày. Sinh viên chưa nộp sẽ bị trừ điểm."
                                           FontSize="13" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="👁 247 lượt xem" FontSize="11" Foreground="#CBD5E1"/>
                                    <TextBlock Text="  •  " Foreground="#CBD5E1" FontSize="11"/>
                                    <TextBlock Text="💬 12 phản hồi" FontSize="11" Foreground="#CBD5E1"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="16,0,0,0" HorizontalAlignment="Right">
                                <TextBlock Text="Hôm qua" FontSize="11" Foreground="#CBD5E1" HorizontalAlignment="Right"/>
                                <TextBlock Text="✏️" FontSize="14" Cursor="Hand" HorizontalAlignment="Right" Margin="0,12,0,4"/>
                                <TextBlock Text="🗑️" FontSize="14" Cursor="Hand" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource NotifCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="46" Height="46" CornerRadius="14"
                                    Background="#EFF6FF" Margin="0,0,16,0">
                                <TextBlock Text="🏆" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border Background="#EFF6FF" CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                        <TextBlock Text="Trí tuệ nhân tạo" FontSize="10" Foreground="#3B82F6" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="Khen thưởng" FontSize="10" Foreground="#64748B"/>
                                </StackPanel>
                                <TextBlock Text="Kết quả điểm kiểm tra tuần 9"
                                           FontSize="14" FontWeight="SemiBold" Foreground="#64748B"/>
                                <TextBlock Text="Điểm kiểm tra tuần 9 đã được cập nhật. Lớp có thành tích tốt với điểm trung bình 8.6/10."
                                           FontSize="13" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="16,0,0,0" HorizontalAlignment="Right">
                                <TextBlock Text="01/04" FontSize="11" Foreground="#CBD5E1" HorizontalAlignment="Right"/>
                                <TextBlock Text="✏️" FontSize="14" Cursor="Hand" HorizontalAlignment="Right" Margin="0,12,0,4"/>
                                <TextBlock Text="🗑️" FontSize="14" Cursor="Hand" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Right: Compose Panel -->
            <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0"
                    BorderThickness="1,0,0,0" Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Soạn thông báo" FontSize="16"
                                   FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,20"/>

                        <!-- Target Class -->
                        <TextBlock Text="Gửi đến lớp" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <Border Background="#F8FAFC" CornerRadius="12" Height="42"
                                Margin="0,0,0,16" Padding="14,0">
                            <Grid>
                                <TextBlock Text="Chọn lớp học..." FontSize="13"
                                           Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <TextBlock Text="▾" FontSize="12" Foreground="#64748B"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Type -->
                        <TextBlock Text="Loại thông báo" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <UniformGrid Columns="2" Margin="0,0,0,16">
                            <Border CornerRadius="10" Background="#EFF6FF"
                                    BorderBrush="#3B82F6" BorderThickness="1.5"
                                    Padding="10,8" Margin="0,0,4,0" Cursor="Hand">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="📢" FontSize="14"/>
                                    <TextBlock Text=" Thông báo" FontSize="12"
                                               Foreground="#3B82F6" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="10" Background="#F8FAFC"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    Padding="10,8" Margin="4,0,0,0" Cursor="Hand">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="⚠️" FontSize="14"/>
                                    <TextBlock Text=" Nhắc nhở" FontSize="12"
                                               Foreground="#64748B" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Title -->
                        <TextBlock Text="Tiêu đề" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <Border Background="#F8FAFC" CornerRadius="12"
                                Height="42" Margin="0,0,0,16" Padding="14,0">
                            <TextBox Background="Transparent" BorderThickness="0"
                                     FontSize="13" Foreground="#94A3B8"
                                     VerticalContentAlignment="Center"
                                     Text="Nhập tiêu đề thông báo..."/>
                        </Border>

                        <!-- Content -->
                        <TextBlock Text="Nội dung" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,8"/>
                        <Border Background="#F8FAFC" CornerRadius="12"
                                Padding="14" Margin="0,0,0,16">
                            <TextBox Background="Transparent" BorderThickness="0"
                                     FontSize="13" Foreground="#94A3B8"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     Height="120" VerticalAlignment="Top"
                                     Text="Nhập nội dung thông báo..."/>
                        </Border>

                        <!-- Options -->
                        <TextBlock Text="Tùy chọn" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,10"/>
                        <CheckBox Content="Gửi thông báo đẩy" FontSize="13"
                                  Foreground="#1E293B" IsChecked="True" Margin="0,6"/>
                        <CheckBox Content="Gửi email cho sinh viên" FontSize="13"
                                  Foreground="#1E293B" Margin="0,6"/>
                        <CheckBox Content="Ghim thông báo lên đầu" FontSize="13"
                                  Foreground="#1E293B" Margin="0,6"/>

                        <Separator Margin="0,16" Background="#F1F5F9"/>

                        <Button Content="📢 Gửi thông báo" Style="{StaticResource PrimaryBtn}"
                                Height="46" FontSize="14"/>
                        <Border CornerRadius="12" Background="#F8FAFC"
                                Padding="0,10" Margin="0,8,0,0" Cursor="Hand" Height="42">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Lưu bản nháp" FontSize="13"
                                       Foreground="#64748B" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
